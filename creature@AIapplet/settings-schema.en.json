{
  "layoutSettings": {
    "type": "layout",
    "pages": [
      "pageCreature",
      "pageAnimation",
      "pageTamagotchi",
      "pageCustomization",
      "pageClipboard"
    ],
    "pageCreature": {
      "type": "page",
      "title": "Creature",
      "sections": [
        "sectionCreatureIdentity",
        "sectionCreatureDetails",
        "sectionLanguage"
      ]
    },
    "pageAnimation": {
      "type": "page",
      "title": "Animation",
      "sections": [
        "sectionAnimation"
      ]
    },
    "sectionCreatureIdentity": {
      "type": "section",
      "title": "Creature identity",
      "keys": [
        "keyCreatureSlug",
        "keyCreatureName",
        "keyProfileImagePath",
        "keyProfileImageSize"
      ]
    },
    "sectionCreatureDetails": {
      "type": "section",
      "title": "Preferences",
      "keys": [
        "keyFavoriteColor",
        "keyCountry",
        "keyBirthdayDay",
        "keyBirthdayMonth"
      ]
    },
    "sectionAnimation": {
      "type": "section",
      "title": "Animated sprite",
      "keys": [
        "keyPanelDisplayMode",
        "keyEmbeddedAppletUuid",
        "keyEmbeddedSlotWidth",
        "keyEmbeddedClickPriority",
        "keyImagePath",
        "keyFrames",
        "keyPausePerFrameInSeconds"
      ]
    },
    "sectionBehaviour": {
      "type": "section",
      "title": "Affective memory",
      "keys": [
        "keyResetMemory"
      ]
    },
    "pageClipboard": {
      "type": "page",
      "title": "Clipboard",
      "sections": [
        "sectionClipboard"
      ]
    },
    "sectionClipboard": {
      "type": "section",
      "title": "Clipboard history",
      "keys": [
        "keyClipboardEnabled",
        "keyClipboardLimit",
        "keySmartClipboardDetection"
      ]
    },
    "sectionProgression": {
      "type": "section",
      "title": "Creature progression",
      "keys": [
        "keyAchievementsEnabled",
        "keyRpgEnabled"
      ]
    },
    "sectionReactions": {
      "type": "section",
      "title": "Smart reactions",
      "keys": [
        "keyMoodEnabled",
        "keyContextualClipboardQuotes"
      ]
    },
    "sectionSystem": {
      "type": "section",
      "title": "Linux/Cinnamon reactions",
      "keys": [
        "keySystemReactionsEnabled",
        "keySystemNotificationsEnabled"
      ]
    },
    "sectionCare": {
      "type": "section",
      "title": "Hunger and cleanliness",
      "keys": [
        "keyFeedCooldownEnabled",
        "keyFeedCooldownHours",
        "keyDailyCareMoodEnabled"
      ]
    },
    "sectionMemory": {
      "type": "section",
      "title": "Memories and special dates",
      "keys": [
        "keyMemoryJournalEnabled",
        "keyBirthdayDay",
        "keyBirthdayMonth",
        "keyHolidayMessagesEnabled"
      ]
    },
    "pageTamagotchi": {
      "type": "page",
      "title": "Tamagotchi",
      "sections": [
        "sectionProgression",
        "sectionReactions",
        "sectionSystem",
        "sectionCare",
        "sectionMemory",
        "sectionBehaviour"
      ]
    },
    "sectionLanguage": {
      "type": "section",
      "title": "Language",
      "keys": [
        "keyLanguage"
      ]
    },
    "pageCustomization": {
      "type": "page",
      "title": "Customization",
      "sections": [
        "sectionBanks",
        "sectionFriendshipIcon"
      ]
    },
    "sectionBanks": {
      "type": "section",
      "title": "Emoji and symbol banks",
