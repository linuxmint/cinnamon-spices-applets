{
  "layoutSettings": {
    "type": "layout",
    "pages": [
      "pageCreature",
      "pageAnimation",
      "pageTamagotchi",
      "pageCustomization",
      "pageClipboard"
    ],
    "pageCreature": {
      "type": "page",
      "title": "Créature",
      "sections": [
        "sectionCreatureIdentity",
        "sectionCreatureDetails",
        "sectionLanguage"
      ]
    },
    "pageAnimation": {
      "type": "page",
      "title": "Animation",
      "sections": [
        "sectionAnimation"
      ]
    },
    "sectionCreatureIdentity": {
      "type": "section",
      "title": "Identité de la créature",
      "keys": [
        "keyCreatureSlug",
        "keyCreatureName",
        "keyProfileImagePath",
        "keyProfileImageSize"
      ]
    },
    "sectionCreatureDetails": {
      "type": "section",
      "title": "Préférences",
      "keys": [
        "keyFavoriteColor",
        "keyCountry",
        "keyBirthdayDay",
        "keyBirthdayMonth"
      ]
    },
    "sectionAnimation": {
      "type": "section",
      "title": "Sprite animé",
      "keys": [
        "keyPanelDisplayMode",
        "keyEmbeddedAppletUuid",
        "keyEmbeddedSlotWidth",
        "keyEmbeddedClickPriority",
        "keyImagePath",
        "keyFrames",
        "keyPausePerFrameInSeconds"
      ]
    },
    "sectionBehaviour": {
      "type": "section",
      "title": "Mémoire affective",
      "keys": [
        "keyResetMemory"
      ]
    },
    "pageClipboard": {
      "type": "page",
      "title": "Presse-papier",
      "sections": [
        "sectionClipboard"
      ]
    },
    "sectionClipboard": {
      "type": "section",
      "title": "Historique du presse-papier",
      "keys": [
        "keyClipboardEnabled",
        "keyClipboardLimit",
        "keySmartClipboardDetection"
      ]
    },
    "sectionProgression": {
      "type": "section",
      "title": "Progression de la créature",
      "keys": [
        "keyAchievementsEnabled",
        "keyRpgEnabled"
      ]
    },
    "sectionReactions": {
      "type": "section",
      "title": "Réactions intelligentes",
      "keys": [
        "keyMoodEnabled",
        "keyContextualClipboardQuotes"
      ]
    },
    "sectionSystem": {
      "type": "section",
      "title": "Réactions Linux/Cinnamon",
      "keys": [
        "keySystemReactionsEnabled",
        "keySystemNotificationsEnabled"
      ]
    },
    "sectionCare": {
      "type": "section",
      "title": "Faim et propreté",
      "keys": [
        "keyFeedCooldownEnabled",
        "keyFeedCooldownHours",
        "keyDailyCareMoodEnabled"
      ]
    },
    "sectionMemory": {
      "type": "section",
      "title": "Souvenirs et dates spéciales",
      "keys": [
        "keyMemoryJournalEnabled",
        "keyBirthdayDay",
        "keyBirthdayMonth",
        "keyHolidayMessagesEnabled"
      ]
    },
    "pageTamagotchi": {
      "type": "page",
      "title": "Tamagotchi",
      "sections": [
        "sectionProgression",
        "sectionReactions",
        "sectionSystem",
        "sectionCare",
        "sectionMemory",
        "sectionBehaviour"
      ]
    },
    "sectionLanguage": {
      "type": "section",
      "title": "Langue",
      "keys": [
        "keyLanguage"
      ]
    },
    "pageCustomization": {
      "type": "page",
      "title": "Personnalisation",
      "sections": [
        "sectionBanks",
        "sectionFriendshipIcon"
      ]
    },
