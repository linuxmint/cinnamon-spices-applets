#. metadata.json->description
msgid ""
"Restart Cinnamon, turn off the screen, lock the screen, switch users, log "
"out, suspend, hibernate, reboot or shut down the computer"
msgstr ""
"Genstart Cinnamon, sluk skærmen, lås skærmen, skift bruger, log ud, hvile, "
"dvale, genstart eller sluk computeren"

#. metadata.json->name
msgid "Exit"
msgstr "Afslut"

#. 5.4->settings-schema.json->sectionOSD->description
#. 6.4->settings-schema.json->sectionOSD->title
msgid "Cinnamon restart"
msgstr "Genstart Cinnamon"

#. 5.4->settings-schema.json->showOSD->description
#. 6.4->settings-schema.json->showOSD->description
msgid "Show OSD while restarting Cinnamon"
msgstr "Vis besked på skærmen, mens Cinnamon genstarter"

#. 5.4->settings-schema.json->showOSD->tooltip
#. 6.4->settings-schema.json->showOSD->tooltip
msgid "OSD: On Screen Display"
msgstr "OSD: On Screen Display"

#. 5.4->settings-schema.json->sectionMenu->description
#. 6.4->settings-schema.json->sectionMenu->title
msgid "Menu options"
msgstr "Menuindstillinger"

#. 5.4->settings-schema.json->showRestartCinnamon->description
#. 6.4->settings-schema.json->showRestartCinnamon->description
msgid "Show the Restart Cinnamon option"
msgstr "Vis “Genstart Cinnamon”"

#. 5.4->settings-schema.json->showSuspend->description
#. 6.4->settings-schema.json->showSuspend->description
msgid "Show the Suspend option"
msgstr "Vis “Hvile”"

#. 5.4->settings-schema.json->showHibernate->description
#. 6.4->settings-schema.json->showHibernate->description
msgid "Show the Hibernate option"
msgstr "Vis “Dvale”"

#. 5.4->settings-schema.json->hibernateNeedsSudo->description
#. 6.4->settings-schema.json->hibernateNeedsSudo->description
msgid "Hibernate needs root user rights (sudo)"
msgstr "Dvale kræver administratorrettigheder (sudo)"

#. 5.4->settings-schema.json->showRestart->description
#. 6.4->settings-schema.json->showRestart->description
msgid "Show the Restart option"
msgstr "Vis “Genstart”"

#. 5.4->settings-schema.json->showPowerOff->description
#. 6.4->settings-schema.json->showPowerOff->description
msgid "Show the Power Off option"
msgstr "Vis “Sluk”"

#. 5.4->settings-schema.json->labelOthers->description
#. 6.4->settings-schema.json->labelOthers->description
msgid ""
"All the menu options below may be managed by the system.\n"
"If they are, you can't see them."
msgstr ""
"Alle nedenstående menupunkter kan administreres af systemet.\n"
"Hvis det er tilfældet, kan du ikke se dem."

#. 5.4->settings-schema.json->showScreenOff->description
#. 6.4->settings-schema.json->showScreenOff->description
msgid "Show the Screen Off option"
msgstr "Vis “Sluk skærm”"

#. 5.4->settings-schema.json->mouse-deactivation-duration->units
#. 6.4->settings-schema.json->mouse-deactivation-duration->units
msgid "seconds"
msgstr "sekunder"

#. 5.4->settings-schema.json->mouse-deactivation-duration->description
#. 6.4->settings-schema.json->mouse-deactivation-duration->description
msgid "Duration of deactivation of the mouse"
msgstr "Varighed af deaktivering af musen"

#. 5.4->settings-schema.json->mouse-deactivation-duration->tooltip
#. 6.4->settings-schema.json->mouse-deactivation-duration->tooltip
msgid ""
"To prevent the monitor from turning on too soon after turning it off, the "
"mouse will be disabled for the number of seconds set here."
msgstr ""
"For at undgå, at skærmen tænder for hurtigt efter, at den er blevet "
"slukket, vil musen være deaktiveret i det antal sekunder, der er angivet "
"her."

#. 5.4->settings-schema.json->showLockscreen->description
#. 6.4->settings-schema.json->showLockscreen->description
msgid "Show the Lock Screen option"
msgstr "Vis “Lås skærm”"

#. 5.4->settings-schema.json->showLockscreen->tooltip
#. 5.4->settings-schema.json->showSwitchUser->tooltip
#. 5.4->settings-schema.json->showLogout->tooltip
#. 6.4->settings-schema.json->showLockscreen->tooltip
#. 6.4->settings-schema.json->showSwitchUser->tooltip
#. 6.4->settings-schema.json->showLogout->tooltip
msgid "Managed by system"
msgstr "Håndteres af systemet"

#. 5.4->settings-schema.json->showSwitchUser->description
#. 6.4->settings-schema.json->showSwitchUser->description
msgid "Show the Switch User option"
msgstr "Vis “Skift bruger”"

#. 5.4->settings-schema.json->showLogout->description
#. 6.4->settings-schema.json->showLogout->description
msgid "Show the Log Out option"
msgstr "Vis “Log ud”"

#. 5.4->settings-schema.json->logoutMode->description
#. 6.4->settings-schema.json->logoutMode->description
msgid "Log Out Mode"
msgstr "Log ud-tilstand"

#. 5.4->settings-schema.json->logoutMode->options
#. 6.4->settings-schema.json->logoutMode->options
msgid "With confirmation"
msgstr "Med bekræftelse"

#. 5.4->settings-schema.json->logoutMode->options
#. 6.4->settings-schema.json->logoutMode->options
msgid "Without confirmation"
msgstr "Uden bekræftelse"

#. 5.4->settings-schema.json->logoutMode->options
#. 6.4->settings-schema.json->logoutMode->options
msgid "Force"
msgstr "Gennemtving"

#. 5.4->settings-schema.json->logoutMode->tooltip
#. 6.4->settings-schema.json->logoutMode->tooltip
msgid ""
"The 'Force' option lets you log out while ignoring inhibitors. Useful when "
"several sessions are open."
msgstr ""
"Med indstillingen “Gennemtving” kan du logge ud uden at tage hensyn til "
"blokeringer. Det er nyttigt, når der er flere sessioner åbne."

#. 6.4->settings-schema.json->page_General->title
msgid "General"
msgstr "Generelt"

#. 6.4->settings-schema.json->page_Shortcuts->title
msgid "Shortcuts"
msgstr "Genveje"

#. 6.4->settings-schema.json->page_Options->title
msgid "Options"
msgstr "Indstillinger"

#. 6.4->settings-schema.json->sectionMaximize->title
msgid "Vertical maximization"
msgstr "Lodret maksimering"

#. 6.4->settings-schema.json->sectionMenuOthers->title
msgid "System-managed menu options"
msgstr "Menuindstillinger håndteret af systemet"

#. 6.4->settings-schema.json->section_DontShowShortcutsInMenu->title
msgid "Menu appearance"
msgstr "Menuens udseende"

#. 6.4->settings-schema.json->section_Shortcuts->title
msgid "Keybindings"
msgstr "Tastegenveje"

#. 6.4->settings-schema.json->section_MenuKeys->title
msgid "Keys used to select certain options in the open menu."
msgstr "Taster brugt til at vælge indstillinger i den åbne menu."

#. 6.4->settings-schema.json->lockOnSuspend->description
msgid "Lock On Suspend"
msgstr "Lås ved hvile"

#. 6.4->settings-schema.json->screenOffUsesXset->description
msgid "Use the hardware method to turn On/Off the screen"
msgstr "Brug hardwaremetoden til at tænde/slukke skærmen"

#. 6.4->settings-schema.json->screenOffUsesXset->tooltip
msgid ""
"The hardware method does not always work correctly.\n"
"In this case, disable this option to use only a software method."
msgstr ""
"Hardwaremetoden fungerer ikke altid korrekt.\n"
"I så fald skal du deaktivere denne indstilling for kun at bruge en "
"softwaremetode."

#. 6.4->settings-schema.json->dontShowShortcutsInMenu->description
msgid "Do not show any shortcut in the menu"
msgstr "Vis ingen genveje i menuen"

#. 6.4->settings-schema.json->kbToggleMenu->description
msgid "Toggle menu"
msgstr "Vis/skjul menu"

#. 6.4->settings-schema.json->kbWakeUpMonitor->description
msgid "Turn screen On/Off"
msgstr "Tænd/sluk skærmen"

#. 6.4->settings-schema.json->kbWakeUpMonitorWithLock->description
msgid "Turn screen On/Off with Lock feature"
msgstr "Tænd/sluk skærmen med låsefunktion"

#. 6.4->settings-schema.json->mkShutdown->description
msgid "Key to select Power Off"
msgstr "Tast til Sluk"

#. 6.4->settings-schema.json->mkShutdown->tooltip
msgid "Single key. Default is U"
msgstr "Enkelt tast; som standard U."

#. 6.4->settings-schema.json->mkRestart->description
msgid "Key to select Restart"
msgstr "Tast til Genstart"

#. 6.4->settings-schema.json->mkRestart->tooltip
msgid "Single key. Default is R"
msgstr "Enkelt tast; som standard R."

#. 6.4->settings-schema.json->mkHibernate->description
msgid "Key to select Hibernate"
msgstr "Tast til Dvale"

#. 6.4->settings-schema.json->mkHibernate->tooltip
msgid "Single key. Default is H"
msgstr "Enkelt tast; som standard H."

#. 6.4->settings-schema.json->mkSuspend->description
msgid "Key to select Suspend"
msgstr "Tast til Hvile"

#. 6.4->settings-schema.json->mkSuspend->tooltip
msgid "Single key. Default is S"
msgstr "Enkelt tast; som standard S."

#. 6.4->settings-schema.json->buttonApplyMenuKeys->description
msgid "Apply these keys to the menu"
msgstr "Anvend disse taster i meneun"

#. 6.4->settings-schema.json->buttonDefaultMenuKeys->description
msgid "Reset to default keys"
msgstr "Nulstil til standardtaster"

#. 6.4->settings-schema.json->alertMenuKeys->description
msgid ""
"Several keys are identical.\n"
"Please correct this and reapply the changes."
msgstr ""
"Flere taster er identiske.\n"
"Ændr det og anvend ændringer."

#. 6.4->settings-schema.json->alreadyUsedKeys->description
msgid "Already used keys (for your information only)"
msgstr "Allerede brugte taster (til oplysning)"

#. 6.4->settings-schema.json->alreadyUsedKeys->tooltip
msgid "There is no point in changing this."
msgstr "Der er ingen grund til at ændre dette."

#. 6.4->settings-schema.json->maximizeSettingsWindow->description
msgid "Vertically maximize this Settings window"
msgstr "Maksimér dette vindue lodret"

#. 6.4->settings-schema.json->maximizeSettingsWindow->tooltip
msgid ""
"This option will only be taken into account the next times this Settings "
"window is opened. "
msgstr ""
"Denne indstilling tages først i betragtning, næste gang dette vindue åbnes."

#. 6.4->settings-schema.json->labelSeparator->description
msgid "────────────────────────────────────────────────────────────────"
msgstr "────────────────────────────────────────────────────────────────"
