# settings-schema.json strings
msgid "Decimal places for temperature"
msgstr "Decimali per la temperatura"

msgid ""
"Number of decimal places to display for temperature. Set to 0 for whole "
"numbers."
msgstr ""
"Numero di cifre decimali da visualizzare per la temperatura. Impostare a 0 "
"per i numeri interi."

msgid "decimal places"
msgstr "cifre decimali"

msgid "Profile Saved: %s"
msgstr "Profilo salvato: %s"

msgid "Active: %s"
msgstr "Attivo: %s"

# Page Titles
msgid "CPU Temperature"
msgstr "Temperatura CPU"

msgid "Profiles"
msgstr "Profili"

msgid "General"
msgstr "Generale"

# Section Titles
msgid "Order of Metrics"
msgstr "Ordine delle metriche"

msgid "Display"
msgstr "Visualizzazione"

msgid "Thresholds"
msgstr "Soglie"

msgid "Colors"
msgstr "Colori"

