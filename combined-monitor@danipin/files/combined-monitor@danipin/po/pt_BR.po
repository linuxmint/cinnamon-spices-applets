# settings-schema.json strings
msgid "Decimal places for temperature"
msgstr "Casas decimais para temperatura"

msgid "Number of decimal places to display for temperature. Set to 0 for whole numbers."
msgstr "Número de casas decimais para exibir a temperatura. Defina como 0 para números inteiros."

msgid "decimal places"
msgstr "casas decimais"

msgid "Profile Saved: %s"
msgstr "Perfil salvo: %s"

msgid "Active: %s"
msgstr "Ativo: %s"

