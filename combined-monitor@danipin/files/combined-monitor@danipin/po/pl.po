# settings-schema.json strings
msgid "Decimal places for temperature"
msgstr "Miejsca dziesiętne dla temperatury"

msgid ""
"Number of decimal places to display for temperature. Set to 0 for whole "
"numbers."
msgstr ""
"Liczba miejsc dziesiętnych do wyświetlenia dla temperatury. Ustaw 0 dla "
"liczb całkowitych."

msgid "decimal places"
msgstr "miejsca dziesiętne"

msgid "Profile Saved: %s"
msgstr "Profil zapisany: %s"

msgid "Active: %s"
msgstr "Aktywny: %s"

