# settings-schema.json strings (Descriptions, Tooltips, Options)
# These are manually added as xgettext does not parse settings-schema.json
msgid "Decimal places for temperature"
msgstr "Nachkommastellen für Temperatur"

msgid ""
"Number of decimal places to display for temperature. Set to 0 for whole "
"numbers."
msgstr ""
"Anzahl der anzuzeigenden Nachkommastellen für die Temperatur. Auf 0 setzen "
"für ganze Zahlen."

msgid "decimal places"
msgstr "Nachkommastellen"

msgid "Profile Saved: %s"
msgstr "Profil gespeichert: %s"

msgid "Active: %s"
msgstr "Aktiv: %s"

