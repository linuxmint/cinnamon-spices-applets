# settings-schema.json strings
msgid "Decimal places for temperature"
msgstr "Decimales para la temperatura"

msgid ""
"Number of decimal places to display for temperature. Set to 0 for whole "
"numbers."
msgstr ""
"Número de decimales para mostrar en la temperatura. Establecer en 0 para "
"números enteros."

msgid "Profile Saved: %s"
msgstr "Perfil Guardado: %s"

msgid "Active: %s"
msgstr "Activo: %s"

