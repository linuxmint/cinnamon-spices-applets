#~ msgid "Fahrenheit (°F)"
#~ msgstr "華氏 (°F)"

#~ msgid ""
#~ "Choose whether the temperature should be displayed in Celsius or "
#~ "Fahrenheit. Threshold values must be adjusted accordingly."
#~ msgstr ""
#~ "温度を摂氏または華氏で表示するかを選択します。しきい値はそれに応じて調整す"
#~ "る必要があります。"

#~ msgid "The LOW color is used below this value (applies to °C and °F)"
#~ msgstr "この値未満で低の色が使用されます (°C および °F に適用)"

#~ msgid "The MED color is used between LOW and MED (applies to °C and °F)"
#~ msgstr "低としきい値 中の間で中の色が使用されます (°C および °F に適用)"

#~ msgid "The HIGH color is used between MED and HIGH (applies to °C and °F)"
#~ msgstr "中としきい値 高の間で高の色が使用されます (°C および °F に適用)"

#~ msgid "Enable color change for TEMP"
