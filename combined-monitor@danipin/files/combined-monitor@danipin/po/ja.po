# CPU
#~ msgid "Show CPU"
#~ msgstr "CPU を表示"

#~ msgid "Text for CPU"
#~ msgstr "CPU のテキスト"

#~ msgid "Custom symbol/icon for CPU. Leave empty for text label."
#~ msgstr ""
#~ "CPU のカスタムシンボル/アイコン。テキストラベルの場合は空のままにします。"

#~ msgid "Show percentage sign (%) for CPU"
#~ msgstr "CPU のパーセンテージ記号 (%) を表示"

#~ msgid ""
#~ "If disabled, only the value (e.g., '45') is displayed without the "
#~ "percentage sign (e.g., '45%'). The 'Show percentage sign (%) (Master "
#~ "Switch)' option in the 'General' tab acts as a master switch."
#~ msgstr ""
#~ "無効にすると、パーセンテージ記号（例: '45%'）なしで値（例: '45'）のみが表"
#~ "示されます。「一般」タブの「パーセンテージ記号 (%) を表示 (マスター スイッ"
#~ "チ)」オプションがマスター スイッチとして機能します。"

#~ msgid "Threshold LOW"
#~ msgstr "しきい値 低"

#~ msgid "The LOW color is used below this value"
#~ msgstr "この値未満で低の色が使用されます"

#~ msgid "Threshold MED"
#~ msgstr "しきい値 中"

#~ msgid "The MED color is used between LOW and MED"
#~ msgstr "低としきい値 中の間で中の色が使用されます"

#~ msgid "Threshold HIGH"
#~ msgstr "しきい値 高"

#~ msgid "The HIGH color is used between MED and HIGH"
#~ msgstr "中としきい値 高の間で高の色が使用されます"

#~ msgid "Enable color change for CPU"
#~ msgstr "CPU の色変更を有効にする"

#~ msgid "Color LOW"
#~ msgstr "色 低"

#~ msgid "Color MED"
#~ msgstr "色 中"

#~ msgid "Color HIGH"
#~ msgstr "色 高"

#~ msgid "Color CRITICAL"
#~ msgstr "色 危機的"

#~ msgid "Used above the HIGH threshold"
#~ msgstr "高しきい値を超えると使用されます"

# TEMP
#~ msgid "Show Temperature"
#~ msgstr "温度を表示"

#~ msgid ""
#~ "Enables the display of CPU temperature. **Important:** On many systems, "
#~ "installing the 'lm-sensors' package and running 'sudo sensors-detect' is "
#~ "necessary for this function to work correctly. Please refer to the "
#~ "instructions in the README.md."
#~ msgstr ""
#~ "CPU 温度の表示を有効にします。**重要:** 多くのシステムでは、この機能が正し"
#~ "く動作するために 'lm-sensors' パッケージをインストールし、'sudo sensors-"
#~ "detect' を実行する必要があります。README.md の手順を参照してください。"

#~ msgid "Show °C symbol"
#~ msgstr "°C 記号を表示"

#~ msgid ""
#~ "Controls whether the Celsius symbol (°C or °F) should be displayed after "
#~ "the value."
#~ msgstr ""
#~ "値の後に摂氏 (°C) または華氏 (°F) の記号を表示するかどうかを制御します。"

#~ msgid "Text for Temperature"
#~ msgstr "温度のテキスト"

#~ msgid "Custom symbol/icon for Temperature. Leave empty for text label."
#~ msgstr ""
#~ "温度のカスタムシンボル/アイコン。テキストラベルの場合は空のままにします。"

#~ msgid "Unit of Measurement"
#~ msgstr "測定単位"

#~ msgid "Celsius (°C)"
