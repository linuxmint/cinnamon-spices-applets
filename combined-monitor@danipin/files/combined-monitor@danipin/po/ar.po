msgstr "شامل"

# CPU
msgid "Show CPU"
msgstr "إظهار المعالج"

msgid "Text for CPU"
msgstr "نص المعالج"

msgid "Custom symbol/icon for CPU. Leave empty for text label."
msgstr "رمز/أيقونة مخصصة للمعالج. اتركه فارغاً للتسمية النصية."

msgid "Show percentage sign (%) for CPU"
msgstr "إظهار علامة النسبة المئوية (%) للمعالج"

msgid ""
"If disabled, only the value (e.g., '45') is displayed without the percentage "
"sign (e.g., '45%'). The 'Show percentage sign (%) (Master Switch)' option in "
"the 'General' tab acts as a master switch."
msgstr ""
"في حالة التعطيل، يتم عرض القيمة فقط (مثلاً '45') بدون علامة النسبة المئوية "
"(مثلاً '%45'). يعمل خيار 'إظهار علامة النسبة المئوية (%) (المفتاح الرئيسي)' "
"في علامة التبويب 'عام' كمفتاح رئيسي."

msgid "Threshold LOW"
msgstr "العتبة المنخفضة"

msgid "The LOW color is used below this value"
msgstr "يستخدم لون المنخفض تحت هذه القيمة"

msgid "Threshold MED"
msgstr "العتبة المتوسطة"

msgid "The MED color is used between LOW and MED"
msgstr "يستخدم لون المتوسط بين المنخفض والمتوسط"

msgid "Threshold HIGH"
msgstr "العتبة العالية"

msgid "The HIGH color is used between MED and HIGH"
msgstr "يستخدم لون العالي بين المتوسط والعالي"

msgid "Enable color change for CPU"
msgstr "تفعيل تغيير اللون للمعالج"

msgid "Color LOW"
msgstr "لون المنخفض"

msgid "Color MED"
msgstr "لون المتوسط"

msgid "Color HIGH"
msgstr "لون العالي"

msgid "Color CRITICAL"
msgstr "لون الحرج"

msgid "Used above the HIGH threshold"
msgstr "يستخدم فوق العتبة العالية"

# TEMP
msgid "Show Temperature"
msgstr "إظهار درجة الحرارة"

msgid ""
"Enables the display of CPU temperature. **Important:** On many systems, "
"installing the 'lm-sensors' package and running 'sudo sensors-detect' is "
"necessary for this function to work correctly. Please refer to the "
"instructions in the README.md."
msgstr ""
"تمكين عرض درجة حرارة المعالج. **هام:** في العديد من الأنظمة، من الضروري "
"تثبيت حزمة 'lm-sensors' وتشغيل 'sudo sensors-detect' لكي تعمل هذه الوظيفة "
"بشكل صحيح. يرجى الرجوع إلى التعليمات في README.md."

msgid "Show °C symbol"
msgstr "إظهار رمز °C"

msgid ""
"Controls whether the Celsius symbol (°C or °F) should be displayed after the "
"value."
msgstr "يتحكم في ما إذا كان يجب عرض رمز الدرجة المئوية (°C أو °F) بعد القيمة."

msgid "Text for Temperature"
msgstr "نص الحرارة"

msgid "Custom symbol/icon for Temperature. Leave empty for text label."
msgstr "رمز/أيقونة مخصصة للحرارة. اتركه فارغاً للتسمية النصية."

msgid "Unit of Measurement"
msgstr "وحدة القياس"

msgid "Celsius (°C)"
msgstr "مئوية (°C)"

msgid "Fahrenheit (°F)"
msgstr "فهرنهايت (°F)"

msgid ""
"Choose whether the temperature should be displayed in Celsius or Fahrenheit. "
"Threshold values must be adjusted accordingly."
msgstr ""
"اختر ما إذا كان يجب عرض درجة الحرارة بالدرجة المئوية أو الفهرنهايت. يجب ضبط "
"قيم العتبة وفقاً لذلك."

msgid "The LOW color is used below this value (applies to °C and °F)"
msgstr ""
"يستخدم لون المنخفض تحت هذه القيمة (ينطبق على الدرجة المئوية والفهرنهايت)"

msgid "The MED color is used between LOW and MED (applies to °C and °F)"
msgstr ""
"يستخدم لون المتوسط بين المنخفض والمتوسط (ينطبق على الدرجة المئوية "
"والفهرنهايت)"

msgid "The HIGH color is used between MED and HIGH (applies to °C and °F)"
msgstr ""
"يستخدم لون العالي بين المتوسط والعالي (ينطبق على الدرجة المئوية والفهرنهايت)"

msgid "Enable color change for TEMP"
msgstr "تفعيل تغيير اللون للحرارة"

msgid "Color LOW (Green)"
msgstr "لون المنخفض (أخضر)"

msgid "Color MED (Orange)"
msgstr "لون المتوسط (برتقالي)"

msgid "Color HIGH (Red-Orange)"
msgstr "لون العالي (أحمر-برتقالي)"

msgid "Color CRITICAL (Red)"
msgstr "لون الحرج (أحمر)"

# RAM
msgid "Show RAM"
msgstr "إظهار الرام"

msgid "Text for RAM"
msgstr "نص الرام"

msgid "Custom symbol/icon for RAM. Leave empty for text label."
msgstr "رمز/أيقونة مخصصة للرام. اتركه فارغاً للتسمية النصية."

msgid "Show percentage sign (%) for RAM"
msgstr "إظهار علامة النسبة المئوية (%) للرام"

msgid "Display Mode"
msgstr "وضع العرض"

msgid "Percentage Usage (%)"
msgstr "نسبة الاستخدام (%)"

msgid "Used Memory (MB/GB)"
msgstr "الذاكرة المستخدمة (م.ب/ج.ب)"

msgid "Free Memory (MB/GB)"
msgstr "الذاكرة الحرة (م.ب/ج.ب)"

msgid ""
"Choose whether percentage usage or used/free memory in MB/GB should be "
"displayed."
msgstr ""
"اختر ما إذا كان سيتم عرض نسبة الاستخدام أو الذاكرة المستخدمة/الحرة "
"بالميجابايت/الجيجابايت."

msgid "Enable color change for RAM"
msgstr "تفعيل تغيير اللون للرام"

# SWAP
msgid "Show SWAP"
msgstr "إظهار المبادلة"

msgid "Text for SWAP"
msgstr "نص المبادلة"

msgid "Custom symbol/icon for SWAP. Leave empty for text label."
msgstr "رمز/أيقونة مخصصة للمبادلة. اتركه فارغاً للتسمية النصية."

msgid "Only show SWAP when used"
msgstr "إظهار المبادلة فقط عند استخدامها"

msgid "If active, it only shows SWAP when usage is greater than 0%."
msgstr "إذا كان نشطاً، فإنه يعرض المبادلة فقط عندما يكون الاستخدام أكبر من 0%."

msgid "Show percentage sign (%) for SWAP"
msgstr "إظهار علامة النسبة المئوية (%) للمبادلة"

msgid "Enable color change for SWAP"
msgstr "تفعيل تغيير اللون للمبادلة"

msgid ""
"If the value is less than or equal to the LOW threshold, the LOW color is "
"used."
msgstr ""
"إذا كانت القيمة أقل من أو تساوي العتبة المنخفضة، يتم استخدام لون المنخفض."

msgid ""
"If the value is greater than LOW and less than or equal to the MED "
"threshold, the MED color is used."
msgstr ""
"إذا كانت القيمة أكبر من المنخفض وأقل من أو تساوي العتبة المتوسطة، يتم "
"استخدام لون المتوسط."

msgid ""
"If the value is greater than MED and less than or equal to the HIGH "
"threshold, the HIGH color is used."
msgstr ""
"إذا كانت القيمة أكبر من المتوسط وأقل من أو تساوي العتبة العالية، يتم استخدام "
"لون العالي."

# Order
msgid "CPU Position"
msgstr "موضع المعالج"

msgid "Position 1 (Left)"
msgstr "الموضع 1 (يسار)"

msgid "Position 2"
msgstr "الموضع 2"

msgid "Position 3"
msgstr "الموضع 3"

msgid "Position 4 (Right)"
msgstr "الموضع 4 (يمين)"

msgid ""
"Defines the display position of CPU. The position is automatically swapped "
"with the metric at the same position."
msgstr ""
"يحدد موضع عرض المعالج. يتم تبديل الموضع تلقائياً مع المقياس في نفس الموضع."

msgid "TEMP Position"
msgstr "موضع الحرارة"

msgid "RAM Position"
msgstr "موضع الرام"

msgid "SWAP Position"
msgstr "موضع المبادلة"

# General
msgid "Update Interval (ms)"
msgstr "فاصل التحديث (ميللي ثانية)"

msgid "Show separator between metrics"
msgstr "إظهار فاصل بين المقاييس"

msgid "Separator Text"
msgstr "نص الفاصل"

msgid "Separator Color"
msgstr "لون الفاصل"

msgid "Show percentage sign (%) (Master Switch)"
msgstr "إظهار علامة النسبة المئوية (%) (المفتاح الرئيسي)"

msgid ""
"If disabled, only the value (e.g., '45') is displayed for all percentage "
"displays without the percentage sign (e.g., '45%'). Individual switches for "
"CPU/RAM/SWAP must also be active."
msgstr ""
"في حالة التعطيل، يتم عرض القيمة فقط (مثلاً '45') لجميع عروض النسبة المئوية "
"بدون علامة النسبة المئوية (مثلاً '%45'). يجب أيضاً أن تكون المفاتيح الفردية "
"للمعالج/الرام/المبادلة نشطة."

# Profiles
msgid "Profile Message Duration (Seconds)"
msgstr "مدة رسالة الملف الشخصي (ثواني)"

msgid ""
"How long should the message ('Profile saved', 'Profile active') be displayed "
"in the panel."
msgstr ""
"ما هي المدة التي يجب أن تظهر فيها الرسالة ('تم حفظ الملف الشخصي'، 'الملف "
"الشخصي نشط') في اللوحة."

msgid "Profile 1 Name"
msgstr "اسم الملف الشخصي 1"

msgid "Enter a custom profile name in the text field!"
msgstr "أدخل اسم ملف شخصي مخصص في حقل النص!"

msgid "Click 'Activate' or 'Save' for Profile 1 in the pop-up menu."
msgstr "انقر على 'تنشيط' أو 'حفظ' للملف الشخصي 1 في القائمة المنبثقة."

msgid "Saved data for Profile 1 (internal)"
msgstr "البيانات المحفوظة للملف الشخصي 1 (داخلي)"

msgid "Profile 2 Name"
msgstr "اسم الملف الشخصي 2"

msgid "Click 'Activate' or 'Save' for Profile 2 in the pop-up menu."
msgstr "انقر على 'تنشيط' أو 'حفظ' للملف الشخصي 2 في القائمة المنبثقة."

msgid "Saved data for Profile 2 (internal)"
msgstr "البيانات المحفوظة للملف الشخصي 2 (داخلي)"

msgid "Profile 3 Name"
msgstr "اسم الملف الشخصي 3"

msgid "Click 'Activate' or 'Save' for Profile 3 in the pop-up menu."
msgstr "انقر على 'تنشيط' أو 'حفظ' للملف الشخصي 3 في القائمة المنبثقة."

msgid "Saved data for Profile 3 (internal)"
msgstr "البيانات المحفوظة للملف الشخصي 3 (داخلي)"

# metadata.json strings
msgid "Combined Monitor"
msgstr "المراقب المجمع"

msgid ""
"A compact and comprehensive system monitor for Cinnamon. Displays CPU, RAM, "
"and SWAP usage in a single panel element. Configure colors, thresholds, "
"separators, and the order of metrics. Supports displaying text, theme icons, "
"or custom symbols for perfect integration into your panel."
msgstr ""
"مراقب نظام مدمج وشامل لسينامون. يعرض استخدام المعالج والذاكرة العشوائية "
"ومساحة التبادل في عنصر لوحة واحد. يمكنك تخصيص الألوان والحدود والفواصل "
"وترتيب المقاييس. يدعم عرض النصوص وأيقونات النظام أو الرموز المخصصة للتكامل "
"المثالي مع اللوحة."

# GPU
msgid "Show GPU Temperature"
msgstr "إظهار حرارة المعالج الرسومي"

msgid ""
"Enables the display of GPU temperature. **Important:** On many systems, "
"installing the 'lm-sensors' package and running 'sudo sensors-detect' is "
"necessary for this function to work correctly. Integrated GPUs (iGPUs) may "
"report their temperature as part of the CPU temperature."
msgstr ""
"تمكين عرض حرارة المعالج الرسومي. **هام:** في العديد من الأنظمة، من الضروري "
"تثبيت حزمة 'lm-sensors' وتشغيل 'sudo sensors-detect' لكي تعمل هذه الوظيفة "
"بشكل صحيح. قد تقوم المعالجات الرسومية المدمجة (iGPUs) بالإبلاغ عن درجة "
"حرارتها كجزء من حرارة المعالج."

msgid "Text for GPU"
msgstr "نص المعالج الرسومي"

msgid "Custom symbol/icon for GPU. Leave empty for text label."
msgstr "رمز/أيقونة مخصصة للمعالج الرسومي. اتركه فارغاً للتسمية النصية."

msgid "Decimal places for GPU temperature"
msgstr "المنازل العشرية لحرارة المعالج الرسومي"

msgid "Enable color change for GPU"
msgstr "تفعيل تغيير اللون للمعالج الرسومي"

# Order
msgid "GPU Position"
msgstr "موضع المعالج الرسومي"
