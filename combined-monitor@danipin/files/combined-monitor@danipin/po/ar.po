# settings-schema.json strings
msgid "Decimal places for temperature"
msgstr "المنازل العشرية للحرارة"

msgid ""
"Number of decimal places to display for temperature. Set to 0 for whole "
"numbers."
msgstr "عدد المنازل العشرية لعرض درجة الحرارة. اضبطه على 0 للأرقام الصحيحة."

msgid "decimal places"
msgstr "منازل عشرية"

msgid "Profile Saved: %s"
msgstr "تم حفظ الملف الشخصي: %s"

msgid "Active: %s"
msgstr "نشط: %s"

# Page Titles
msgid "CPU Temperature"
msgstr "حرارة المعالج"

msgid "Profiles"
msgstr "الملفات الشخصية"

msgid "General"
msgstr "عام"

# Section Titles
msgid "Order of Metrics"
msgstr "ترتيب المقاييس"

msgid "Display"
msgstr "العرض"

msgid "Thresholds"
msgstr "العتبات"

msgid "Colors"
msgstr "الألوان"

msgid "Thresholds (in °C)"
msgstr "العتبات (بالدرجة مئوية)"

msgid "Settings"
