#. applet.js:77
msgid "Click to disable effect"
msgstr "Haga clic para desactivar el efecto"

#. applet.js:79
msgid "Click to desaturate the desktop"
msgstr "Haz clic para desaturar el escritorio"

#. applet.js:87
msgid "Will automatically desaturate in"
msgstr "Se desaturará automáticamente en"

#. applet.js:89
msgid "Will automatically disable in"
msgstr "Se desactivará automáticamente en"

#. applet.js:91
msgid "minutes"
msgstr "minutos"

#. applet.js:94
msgid "Will automatically desaturate at"
msgstr "Se desaturará automáticamente en"

#. applet.js:96
msgid "Will automatically disable at"
msgstr "Se desactivará automáticamente en"

#. metadata.json->name
msgid "Desaturate All"
msgstr "Desaturar todo"

#. metadata.json->description
msgid "Convert your screen to gray-scale."
msgstr "Convierte tu pantalla a escala de grises."

#. settings-schema.json->saturation->description
msgid "Color saturation when desaturation effect is enabled (percent)"
msgstr ""
"Saturación del color cuando el efecto de desaturación está activado "
"(porcentaje)"

#. settings-schema.json->keybinding->description
msgid "Shortcut to toggle desaturation effect"
msgstr "Acceso directo para activar el efecto de desaturación"

#. settings-schema.json->automatic->description
msgid "Automatic"
msgstr "Automático"

#. settings-schema.json->automatic->tooltip
msgid ""
"Automatically enable and disable the desaturation effect based on the time "
"of day"
msgstr ""
"Activar y desactivar automáticamente el efecto de desaturación en función de "
"la hora del día"

#. settings-schema.json->start-timechooser->description
msgid "Time of day to automatically enable"
msgstr "Hora del día para activar automáticamente"

#. settings-schema.json->end-timechooser->description
msgid "Time of day to automatically disable"
msgstr "Hora del día para desactivar automáticamente"

#. settings-schema.json->resume-on-startup->description
msgid "Restore desaturation effect state on startup"
msgstr "Restaurar el estado del efecto de desaturación al arrancar"

#. settings-schema.json->resume-on-startup->tooltip
msgid "Restore the previously set desaturation state when cinnamon starts"
msgstr ""
"Restaurar el estado de desaturación previamente establecido cuando se inicia "
"Cinnamon"

#. settings-schema.json->fade-time->description
msgid "Saturation fade in/out duration (seconds)"
msgstr "Duración del fundido de entrada/salida de la saturación (segundos)"
