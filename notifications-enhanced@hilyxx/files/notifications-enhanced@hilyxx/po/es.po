#. metadata.json->name
msgid "Notifications-Enhanced"
msgstr "Notificaciones-Mejoradas"

#. metadata.json->description
msgid "A notification applet but with more options"
msgstr "Un applet de notificación pero con más opciones"

#. settings-schema.json->section1->description
msgid "Behavior"
msgstr "Comportamiento"

#. settings-schema.json->ignoreTransientNotifications->description
msgid "Ignore transient notifications"
msgstr "Ignorar las notificaciones transitorias"

#. settings-schema.json->ignoreTransientNotifications->tooltip
msgid "Check this to ignore transient notifications."
msgstr "Marque esta opción para ignorar las notificaciones transitorias."

#. settings-schema.json->section2->description
msgid "Display"
msgstr "Mostrar"

#. settings-schema.json->showNotificationCount->description
msgid "Show the number of notifications"
msgstr "Mostrar el número de notificaciones"

#. settings-schema.json->showEmptyTray->description
msgid "Show notification tray"
msgstr "Mostrar bandeja de notificaciones"

#. settings-schema.json->showEmptyTray->tooltip
msgid "Check this to always show the notification tray."
msgstr "Marque esta opción para mostrar siempre la bandeja de notificaciones."

#. settings-schema.json->showDisturbIcon->description
msgid "Always show 'Do Not Disturb' icon"
msgstr "Mostrar siempre el icono 'No molestar'"

#. settings-schema.json->showDisturbIcon->tooltip
msgid ""
"Check this to show the 'Do Not Disturb icon' on the panel even when the "
"'Show notification tray' option is disabled."
msgstr ""
"Marque esta opción para mostrar el icono 'No molestar' en el panel aunque la "
"opción 'Mostrar bandeja de notificaciones' esté desactivada."

#. settings-schema.json->showNotificationSettings->description
msgid "Show notification settings in the menu"
msgstr "Mostrar la configuración de las notificaciones en el menú"

#. settings-schema.json->section3->description
msgid "Keyboard shortcuts"
msgstr "Atajos de teclado"

#. settings-schema.json->keyOpen->description
msgid "Show notifications"
msgstr "Mostrar notificaciones"

#. settings-schema.json->keyOpen->tooltip
msgid "Set keybinding(s) to show the notification popup menu."
msgstr ""
"Establezca combinaciones de teclas para mostrar el menú emergente de "
"notificaciones."

#. settings-schema.json->keyClear->tooltip
msgid "Set keybinding(s) to clear all notifications."
msgstr ""
"Establezca combinaciones de teclas para borrar todas las notificaciones."

#. settings-schema.json->keyMute->description
msgid "Enable or disable notifications"
msgstr "Habilitar o deshabilitar notificaciones"

#. settings-schema.json->keyMute->tooltip
msgid "Set keybinding(s) to enable or disable notifications."
msgstr ""
"Establezca la(s) combinación(es) de teclas para activar o desactivar las "
"notificaciones."

#. settings-schema.json->historyEnabled->description
msgid "Enable notification history"
msgstr "Activar historial de notificaciones"

#. settings-schema.json->historyEnabled->tooltip
msgid "Store notifications to disk for later review."
msgstr "Almacenar notificaciones en disco para revisarlas más tarde."

#. settings-schema.json->historyRetentionDays->description
msgid "Keep history for days"
msgstr "Conservar historial durante días"

#. settings-schema.json->historyRetentionDays->tooltip
msgid ""
"Notification history files older than this will be deleted automatically."
msgstr ""
"Los archivos del historial de notificaciones más antiguos que este valor se "
"eliminarán automáticamente."

#. settings-schema.json->historyPageSize->description
msgid "Notifications per page"
msgstr "Notificaciones por página"

#. settings-schema.json->historyPageSize->tooltip
msgid "How many historical notifications to show per page."
msgstr "Número de notificaciones históricas a mostrar por página."

#. settings-schema.json->btnSystemSettings->description
msgid "Open notification settings"
msgstr "Abrir configuración de notificaciones"
