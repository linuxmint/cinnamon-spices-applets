{
    "section1": {
        "type": "section",
        "description": "Behavior"
     },
     "ignoreTransientNotifications": {
        "type": "switch",
        "default":true,
        "description": "Ignore transient notifications",
        "tooltip" : "Check this to ignore transient notifications."
    },
    "section2": {
        "type": "section",
        "description": "Display"
    },
    "showNotificationCount": {
        "type": "switch",
        "default":true,
        "description": "Show the number of notifications"
    },
    "showEmptyTray": {
        "type": "switch",
        "default":true,
        "description": "Show notification tray",
        "tooltip": "Check this to always show the notification tray."
    },
    "showDisturbIcon": {
        "type": "switch",
        "default":false,
        "dependency":"!showEmptyTray",
        "description": "Always show 'Do Not Disturb' icon",
        "tooltip": "Check this to show the 'Do Not Disturb icon' on the panel even when the 'Show notification tray' option is disabled."
    },
    "showNotificationSettings": {
        "type": "switch",
        "default":false,
        "description": "Show notification settings in the menu"
    },
    "section3": {
        "type": "section",
        "description": "Keyboard shortcuts"
    },
    "keyOpen": {
        "type": "keybinding",
        "description": "Show notifications",
        "default": "<Super>n",
        "tooltip" : "Set keybinding(s) to show the notification popup menu."
   },
   "keyClear": {
        "type": "keybinding",
        "description": "Clear notifications",
        "default": "<Shift><Super>c",
        "tooltip" : "Set keybinding(s) to clear all notifications."
   },
    "keyMute": {
        "type": "keybinding",
        "description": "Enable or disable notifications",
        "default": "<Shift><Super>m",
        "tooltip": "Set keybinding(s) to enable or disable notifications."
    },    
   "section4": {
        "type": "section",
        "description": "Notification history"
   },
   "historyEnabled": {
        "type": "switch",
        "default": true,
        "description": "Enable notification history",
        "tooltip": "Store notifications to disk for later review."
    },
    "historyRetentionDays": {
        "type": "spinbutton",
        "default": 30,
        "min": 1,
        "max": 365,
        "step": 1,
        "description": "Keep history for days",
        "tooltip": "Notification history files older than this will be deleted automatically."
    },
    "historyPageSize": {
        "type": "spinbutton",
        "default": 20,
        "min": 5,
        "max": 100,
        "step": 5,
        "description": "Notifications per page",
        "tooltip": "How many historical notifications to show per page."
    },
   "section5": {
        "type": "section",
        "description": ""
   },
   "btnSystemSettings" : {
        "type" : "button",
        "description" : "Open notification settings",
        "callback": "on_btn_open_system_settings_clicked"
    }
}
