  "labelsOn": {
    "type": "switch",
    "default": true,
    "description": "Labels"
  },
  "borderOn": {
    "type": "switch",
    "default": false,
    "description": "Add a border to each graph"
  },
  "borderRadius": {
    "type": "scale",
    "default": 0,
    "min": 0,
    "max": 25,
    "step": 1,
    "description": "Radius of curvature in corners",
    "dependency": "borderOn"
  },
  "graphStep": {
    "type": "combobox",
    "default": 1,
    "options": {
      "1px": 1,
      "2px": 2,
      "4px": 4,
      "8px": 8,
      "16px": 16,
      "32px": 32,
      "64px": 64
    },
    "description": "The width of each graphic must be a multiple of:"
  },
  "graphStepApply": {
    "type": "button",
    "callback": "on_apply_width_multiple",
    "description": "Apply this multiple"
  },
  "graphSpacing": {
    "type": "scale",
    "default": 1,
    "description": "Graph spacing",
    "min": -1,
    "max": 10,
    "step": 1,
    "show-value": true
  },
  "thickness": {
    "type": "scale",
    "default": 1,
    "description": "Curves thickness",
    "min": 1,
    "max": 5,
    "step": 1,
    "show-value": true
  },
  "ledForCurves": {
    "type": "combobox",
    "default": "●",
    "description": "Led for curves",
    "options": {
      "●": "●",
      "⬤": "⬤",
      "◉": "◉"
    }
  },
  "ledLocation": {
    "type": "combobox",
    "default": "LO",
    "description": "Led location",
    "options": {
      "Left": "LO",
      "Right": "RO"
    }
  },
  "useIconSize": {
    "type": "switch",
    "default": false,
    "description": "Limit height to the size of a colored icon"
  },
  "graphHeightPercent": {
    "type": "scale",
    "default": 100,
    "description": "Graph height (% of panel height)",
    "min": 40,
    "max": 100,
    "step": 1,
    "show-value": true,
    "dependency": "!useIconSize"
  },
  "graphHeight": {
    "type": "generic",
    "default": 40
  },
  "refreshRate": {
    "type": "scale",
    "default": 1250,
    "description": "Refresh Rate (ms)",
    "min": 100,
    "max": 3000,
    "step": 50,
    "show-value": true
  },
  "labelColor": {
    "type": "colorchooser",
    "default": "rgba(238, 238, 236, 1)",
    "description": "Label Color"
  },
  "borderColor": {
    "type": "colorchooser",
    "default": "rgba(238, 238, 236, 1)",
    "description": "Border Color",
    "dependency": "borderOn"
  },
  "backgroundColor": {
    "type": "colorchooser",
    "default": "rgba(48, 48, 48, 0.1)",
    "description": "Background Color"
  },
  "percentAtEndOfLine": {
    "type": "switch",
    "default": false,
    "description": "Place % at the very end of the line"
  },
  "tooltipFontSize": {
    "type": "scale",
    "default": 16,
    "min": 8,
    "max": 32,
    "step": 1,
    "description": "Font size (px)"
  },
  "removeEnlightenment": {
    "type": "button",
    "dependency": "isHighlighted",
    "callback": "_removeEnlightenment",
    "description": "Remove Enlightenment of this applet"
  },
  "displayOrderLabel": {
    "type": "label",
    "description": "Choose the order in which the boxes of this applet are displayed in the panel.\nDo not change these names!"
  },
  "displayOrder": {
    "type": "list",
    "default": [

    ],
    "columns": [
      {
        "id": "id",
        "title": "Name",
        "type": "string",
        "expand-width": true
      }
    ],
    "show-buttons": true,
    "hidden-buttons": [
      "+",
      "-",
      "edit"
    ],
    "description": "Display order in the panel"
  },
  "displayOrderApply": {
    "type": "button",
    "description": "Apply",
    "callback": "controlDisplayOrder"
  },
  "displayOrderReinit": {
    "type": "button",
    "description": "Reset",
    "callback": "reinitDisplayOrder"
  },
  "CPU_enabled": {
    "type": "switch",
    "default": true,
    "description": "Enable"
  },
  "CPU_enabledTooltip": {
    "type": "switch",
    "default": true,
    "description": "Enable Tooltip"
  },
  "CPU_labelOn": {
    "type": "switch",
    "default": true,
    "description": "Display this label"
  },
  "CPU_labelForeground": {
    "type": "switch",
    "default": true,
    "description": "Bring this label to the foreground"
  },
  "CPU_labelPos": {
    "type": "scale",
    "default": 0,
    "description": "Vertical position offset (pixels)",
    "min": -20,
    "max": 20,
    "step": 1,
    "tooltip": "Negative: to the top.\nPositive: to the bottom."
  },
  "CPU_labelZoom": {
    "type": "combobox",
    "default": 1,
    "description": "Label zoom",
    "options": {
      "1": 1,
      "2": 2,
      "3": 3,
      "4": 4
    }
  },
  "CPU_labelCustomized": {
    "type": "switch",
    "default": false,
    "description": "Customize this label"
  },
  "CPU_labelCustom": {
    "type": "entry",
    "default": "𝄜",
    "description": "Custom label",
    "tooltip": "You can use emojis."
  },
  "CPU_squared": {
    "type": "switch",
    "default": false,
    "description": "Square view"
  },
  "CPU_width": {
    "type": "scale",
    "default": 64,
    "description": "Width",
    "min": 10,
    "max": 320,
    "step": 1,
    "show-value": true,
    "dependency": "!CPU_squared"
  },
  "CPU_mergeAll": {
    "type": "switch",
    "default": false,
    "description": "Merge all"
  },
  "CPU_ignoreHyperthreading": {
    "type": "switch",
    "default": false,
    "description": "Ignore Hyper-Threading",
    "dependency": "CPU_mergeAll",
    "tooltip": "Example: An 8-core processor with Hyper-Threading technology appears to have 16 cores, even though it does not."
  },
  "CPU_showLoadOverTime": {
    "type": "switch",
    "default": false,
    "description": "Show only the CPU Load Over Time",
    "dependency": "CPU_mergeAll"
  },
  "CPU_showLoadOverTimeHowManyBars": {
    "type": "combobox",
    "description": "How many bars?",
    "default": 8,
    "options": {
      "1": 1,
      "2": 2,
      "4": 4,
      "8": 8,
      "16": 16,
      "32": 32,
      "64": 64
    },
    "tooltip": "Related to CPU Load Over Time",
    "dependency": "CPU_mergeAll"
  },
  "CPU_showTemp": {
    "type": "switch",
    "default": true,
    "description": "Show the CPU temperature"
  },
  "CPU_temp_hovering_only": {
    "type": "switch",
    "default": false,
    "description": "Only display when hovering over this applet",
    "dependency": "CPU_showTemp"
  },
  "CPU_tempInFahrenheit": {
    "type": "switch",
    "default": false,
    "description": "Fahrenheit degrees",
    "dependency": "CPU_showTemp"
  },
  "CPU_tempPath": {
    "type": "entry",
    "default": "/sys/class/thermal/thermal_zone1/temp",
    "expand-width": true,
    "description": "Path to the system file used to check the CPU temperature"
  },
  "CPU_tempHigh": {
    "type": "entry",
    "default": "65",
    "expand-width": true,
    "description": "High CPU Temperature (°C)",
    "tooltip": "Refer to your CPU documentation."
  },
  "CPU_tempCrit": {
    "type": "entry",
    "default": "75",
    "expand-width": true,
    "description": "Critical CPU Temperature (°C)",
    "tooltip": "Refer to your CPU documentation.\nMust be greater than the High CPU Temperature."
  },
  "CPU_tempCorner": {
    "type": "combobox",
    "default": "TR",
    "description": "Corner in which to display the temperature",
    "options": {
      "Top Right": "TR",
      "Top Left": "TL",
      "Bottom Right": "BR",
      "Bottom Left": "BL"
    }
  },
  "CPU_tempFontFactor": {
    "type": "scale",
    "default": 33,
    "min": 20,
    "max": 60,
    "step": 1,
    "units": "%",
    "description": "Font size: percentage of the box height"
  },
  "CPU_tempColor": {
    "type": "colorchooser",
    "default": "rgba(238, 238, 236, 1)",
    "description": "Normal Temperature Color"
  },
  "CPU_tempColorHigh": {
    "type": "colorchooser",
    "default": "rgba(255, 120, 0, 1)",
    "description": "High Temperature Color"
  },
  "CPU_tempColorCrit": {
    "type": "colorchooser",
    "default": "rgba(224, 27, 36, 1)",
    "description": "Critical Temperature Color"
  },
  "CPU_byActivity": {
    "type": "switch",
    "default": false,
    "description": "Color by activity level"
  },
  "CPU_useProgressiveColors": {
    "type": "switch",
    "dependency": "CPU_byActivity",
    "default": false,
    "description": "Use automatic colors"
  },
  "CPU_colorExplanation": {
    "type": "label",
    "description": "The CPUs are colored in groups of four: CPU0, CPU1, CPU2, and CPU3.\nThe fifth, named CPU4, will have the same color as CPU0; the sixth, CPU5, will have the same color as CPU1, and so on."
  },
  "CPU_color0": {
    "type": "colorchooser",
    "default": "rgba(255, 255, 255, 1)",
    "description": "CPU0 Color"
  },
  "CPU_color1": {
    "type": "colorchooser",
    "default": "rgba(255, 255, 255, 1)",
    "description": "CPU1 Color"
  },
  "CPU_color2": {
    "type": "colorchooser",
    "default": "rgba(255, 255, 255, 1)",
    "description": "CPU2 Color"
  },
  "CPU_color3": {
    "type": "colorchooser",
    "default": "rgba(255, 255, 255, 1)",
    "description": "CPU3 Color"
  },
  "CPU_activity_0_20": {
    "type": "colorchooser",
    "default": "rgba(26,95,180, 1)",
    "description": "0-20"
  },
  "CPU_activity_20_40": {
    "type": "colorchooser",
    "default": "rgba(38, 162, 105, 1)",
    "description": "20-40"
  },
  "CPU_activity_40_60": {
    "type": "colorchooser",
    "default": "rgba(229, 165, 10, 1)",
    "description": "40-60"
  },
  "CPU_activity_60_80": {
    "type": "colorchooser",
    "default": "rgba(198, 70, 0, 1)",
    "description": "60-80"
  },
  "CPU_activity_80_100": {
    "type": "colorchooser",
    "default": "rgba(165, 29, 45, 1)",
    "description": "80-100"
  },
  "Mem_enabled": {
    "type": "switch",
    "default": true,
    "description": "Enable"
  },
  "Mem_onlyUsedAvailable": {
    "type": "switch",
    "default": false,
    "description": "Display only Used and Available memory"
  },
  "Mem_enabledTooltip": {
    "type": "switch",
    "default": true,
    "description": "Enable Tooltip"
  },
  "Mem_enabledBufferCacheSharedTooltip": {
    "type": "switch",
    "default": true,
    "description": "Enable Buffer/Cache/Shared Tooltip",
    "dependency": "Mem_enabledTooltip"
