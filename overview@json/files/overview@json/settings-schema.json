{
    "layout": {
        "type": "layout",
        "pages": [
            "overview",
            "search-engines-page"
        ],
        "overview": {
            "type": "page",
            "title": "Overview",
            "sections": [
                "overview-controls",
                "overview-tiles",
                "panel-appear",
                "dictionary-section",
                "newsletter-section"
            ]
        },
        "overview-controls": {
            "type": "section",
            "title": "Controls",
            "keys": [
                "overview-key",
                "overview-hot-corner"
            ]
        },
        "overview-tiles": {
            "type": "section",
            "title": "Tiles & Style",
            "keys": [
                "overview-color-theme",
                "use-tile-style",
                "overview-tile-style",
                "show-news-feed",
                "news-rows",
                "weather-city",
                "show-recent-files",
                "recent-files-count"
            ]
        },
        "panel-appear": {
            "type": "section",
            "title": "Panel Button",
            "keys": [
                "menu-icon-custom",
                "menu-icon",
                "menu-icon-size-custom",
                "menu-icon-size",
                "menu-label"
            ]
        },
        "search-engines-page": {
            "type": "page",
            "title": "Search Engines",
            "sections": [
                "search-engines-section",
                "search-options-section"
            ]
        },
        "search-engines-section": {
            "type": "section",
            "title": "Web Search Engines",
            "keys": [
                "search-engine-google",
                "search-engine-youtube",
                "search-engine-duckduckgo",
                "search-engine-bing",
                "search-engine-wikipedia",
                "search-engine-github",
                "search-engine-stackoverflow",
                "search-engine-reddit",
                "search-engine-imdb",
                "search-engine-openstreetmap"
            ]
        },
        "search-options-section": {
            "type": "section",
            "title": "Search Options",
            "keys": [
                "search-web-enabled",
                "search-web-new-tab",
                "search-web-rows"
            ]
        },
        "dictionary-section": {
            "type": "section",
            "title": "Dictionary",
            "keys": [
                "enable-dictionary",
                "enable-ai-summary",
                "groq-api-key"
            ]
        },
        "newsletter-section": {
            "type": "section",
            "title": "AI Newsletter",
            "keys": [
                "enable-newsletter"
            ]
        }
    },
    "categories": {
        "type": "generic",
        "default": []
    },
    "custom-menu-width": {
        "type": "generic",
        "default": 800
    },
    "custom-menu-height": {
        "type": "generic",
        "default": 530
    },
    "recent-apps": {
        "type": "generic",
        "default": []
    },
    "search-start-folder": {
        "type": "generic",
        "default": ""
    },
    "folder-categories": {
        "type": "generic",
        "default": []
    },
    "all-apps-old-style": {
        "type": "generic",
        "default": false
    },
    "last-category": {
        "type": "generic",
        "default": "all"
    },
    "applications-view-mode": {
        "type": "generic",
        "default": 1
    },
    "description-placement": {
        "type": "generic",
        "default": 0
    },
    "show-sidebar": {
        "type": "generic",
        "default": true
    },
    "sidebar-placement": {
        "type": "generic",
        "default": 1
    },
    "system-buttons-placement": {
        "type": "generic",
        "default": "bottom"
    },
    "sidebar-favorites": {
        "type": "generic",
        "default": 3
    },
    "startup-view": {
        "type": "generic",
        "default": 0
    },
    "search-placement": {
        "type": "generic",
        "default": "sidebar-top"
    },
    "show-categories": {
        "type": "generic",
        "default": true
    },
    "show-places-category": {
        "type": "generic",
        "default": true
    },
    "show-recents-category": {
        "type": "generic",
        "default": true
    },
    "show-favorite-apps-category": {
        "type": "generic",
        "default": false
    },
    "show-home-folder-category": {
        "type": "generic",
        "default": true
    },
    "show-emoji-category": {
        "type": "generic",
        "default": true
    },
    "overlay-key": {
        "type": "generic",
        "default": ""
    },
    "activate-on-hover": {
        "type": "generic",
        "default": false
    },
    "hover-delay": {
        "type": "generic",
        "default": 300
    },
    "enable-animation": {
        "type": "generic",
        "default": true
    },
    "open-on-category": {
        "type": "generic",
        "default": false
    },
    "category-click": {
        "type": "generic",
        "default": false
    },
    "enable-autoscroll": {
        "type": "generic",
        "default": true
    },
    "show-hidden-files": {
        "type": "generic",
        "default": false
    },
    "enable-emoji-search": {
        "type": "generic",
        "default": true
    },
    "web-search-option": {
        "type": "generic",
        "default": 0
    },
    "web-search-custom-url": {
        "type": "generic",
        "default": ""
    },
    "web-suggestions": {
        "type": "generic",
        "default": false
    },
    "enable-home-folder-search": {
        "type": "generic",
        "default": true
    },
    "enable-web-history-search": {
        "type": "generic",
        "default": false
    },
    "enable-web-bookmarks-search": {
        "type": "generic",
        "default": false
    },
    "enable-wikipedia-search": {
        "type": "generic",
        "default": false
    },
    "wikipedia-language": {
        "type": "generic",
        "default": "en"
    },
    "apps-grid-icon-size": {
        "type": "generic",
        "default": 48
    },
    "apps-list-icon-size": {
        "type": "generic",
        "default": 24
    },
    "category-icon-size": {
        "type": "generic",
        "default": 16
    },
    "use-box-style": {
        "type": "generic",
        "default": true
    },
    "show-fav-box": {
        "type": "generic",
        "default": true
    },
    "show-fav-box-avatar": {
        "type": "generic",
        "default": true
    },
    "fav-box-avatar-size": {
        "type": "generic",
        "default": 48
    },
    "show-fav-box-apps": {
        "type": "generic",
        "default": true
    },
    "fav-box-icon-size": {
        "type": "generic",
        "default": 28
    },
    "fav-box-sys-horizontal": {
        "type": "generic",
        "default": false
    },
    "use-menu-tile-style": {
        "type": "generic",
        "default": true
    },
    "menu-tile-style": {
        "type": "generic",
        "default": "metro"
    },
    "enable-browser-history": {
        "type": "generic",
        "default": false
    },
    "overview-key": {
        "type": "keybinding",
        "default": "<Super>a",
        "description": "Key for app overview",
        "tooltip": "Keyboard shortcut to open the fullscreen app overview"
    },
    "overview-hot-corner": {
        "type": "combobox",
        "default": "none",
        "description": "Overview hot corner",
        "options": {
            "None": "none",
            "Top Left": "top-left",
            "Top Right": "top-right",
            "Bottom Left": "bottom-left",
            "Bottom Right": "bottom-right"
        },
        "tooltip": "Screen corner that opens the overview when hovered"
    },
    "use-tile-style": {
        "type": "switch",
        "default": true,
        "description": "Use tile style",
        "tooltip": "Use coloured tile styling for app buttons in the overview"
    },
    "overview-tile-style": {
        "dependency": "use-tile-style",
        "type": "combobox",
        "default": "metro",
        "description": "Tile style",
        "options": {
            "Light Palette": "light-palette",
            "Dark Palette": "dark-palette",
            "Metro": "metro",
            "CSS Only": "css"
        },
        "tooltip": "Colour palette for overview app tiles (tile colours and style only)"
    },
    "overview-color-theme": {
        "type": "combobox",
        "default": "light",
        "description": "Theme palette",
        "options": {
            "Light": "light",
            "Dark": "dark",
            "Use cinnamon.css": "cinnamon-css"
        },
        "tooltip": "Controls the overall background and text colours of the overview panel. 'Use cinnamon.css' lets your desktop theme fully control it."
    },
    "menu-icon-custom": {
        "type": "switch",
        "default": false,
        "description": "Use custom panel icon",
        "tooltip": "Use a custom icon instead of the default"
    },
    "menu-icon": {
        "dependency": "menu-icon-custom",
        "type": "iconfilechooser",
        "default": "",
        "description": "Panel icon",
        "tooltip": "Custom icon for the panel button"
    },
    "menu-icon-size-custom": {
        "type": "switch",
        "default": false,
        "description": "Custom icon size",
        "tooltip": "Use a custom size for the panel icon"
    },
    "menu-icon-size": {
        "dependency": "menu-icon-size-custom",
        "type": "spinbutton",
        "default": 24,
        "min": 16,
        "max": 64,
        "step": 2,
        "units": "pixels",
        "description": "Icon size",
        "tooltip": "Size of the panel icon in pixels"
    },
    "menu-label": {
        "type": "entry",
        "default": "",
        "description": "Panel label",
        "tooltip": "Text label next to the panel icon"
    },
    "show-news-feed": {
        "type": "switch",
        "default": true,
        "description": "Show news feed",
        "tooltip": "Show a scrollable news thumbnail strip at the top of the Favourites view"
    },
    "news-rows": {
        "type": "spinbutton",
        "default": 1,
        "min": 1,
        "max": 3,
        "step": 1,
        "units": "rows",
        "description": "News feed rows",
        "tooltip": "Number of news rows to show (1 = World News, 2 = + Science & Tech, 3 = + Film & Music)"
    },
    "weather-city": {
        "type": "entry",
        "default": "Chorbane",
        "description": "Weather city",
        "tooltip": "City name for weather forecast (e.g. Tunis, London, New York). Leave blank to hide."
    },
    "sidebar-icon-size": {
        "type": "spinbutton",
        "default": 24,
        "min": 16,
        "max": 48,
        "step": 2,
        "units": "px",
        "description": "Sidebar icon size",
        "tooltip": "Size of category icons in the sidebar"
    },
    "search-engine-google": {
        "type": "switch",
        "default": true,
        "description": "Google",
        "tooltip": "Include Google in web search results"
    },
    "search-engine-youtube": {
        "type": "switch",
        "default": true,
        "description": "YouTube",
        "tooltip": "Include YouTube in web search results"
    },
    "search-engine-duckduckgo": {
        "type": "switch",
        "default": true,
        "description": "DuckDuckGo",
        "tooltip": "Include DuckDuckGo in web search results"
    },
    "search-engine-bing": {
        "type": "switch",
        "default": false,
        "description": "Bing",
        "tooltip": "Include Bing in web search results"
    },
    "search-engine-wikipedia": {
        "type": "switch",
        "default": true,
        "description": "Wikipedia",
        "tooltip": "Include Wikipedia in web search results"
    },
    "search-engine-github": {
        "type": "switch",
        "default": true,
        "description": "GitHub",
        "tooltip": "Include GitHub in web search results"
    },
    "search-engine-stackoverflow": {
        "type": "switch",
        "default": false,
        "description": "Stack Overflow",
        "tooltip": "Include Stack Overflow in web search results"
    },
    "search-engine-reddit": {
        "type": "switch",
        "default": false,
        "description": "Reddit",
        "tooltip": "Include Reddit in web search results"
    },
    "search-engine-imdb": {
        "type": "switch",
        "default": false,
        "description": "IMDb",
        "tooltip": "Include IMDb in web search results"
    },
    "search-engine-openstreetmap": {
        "type": "switch",
        "default": false,
        "description": "OpenStreetMap",
        "tooltip": "Include OpenStreetMap in web search results"
    },
    "search-web-enabled": {
        "type": "switch",
        "default": true,
        "description": "Show web search results",
        "tooltip": "Show web search engine shortcuts below app results"
    },
    "search-web-new-tab": {
        "type": "switch",
        "default": true,
        "description": "Open searches in new tab",
        "tooltip": "Open web searches in a new browser tab"
    },
    "search-web-rows": {
        "type": "spinbutton",
        "default": 1,
        "min": 1,
        "max": 3,
        "step": 1,
        "units": "rows",
        "description": "Search engine rows",
        "tooltip": "Number of rows of web search engine cards to show (1\u20133)"
    },
    "enable-dictionary": {
        "type": "checkbox",
        "default": true,
        "description": "Show dictionary panel when searching a word",
        "tooltip": "When you type a single word, show its Oxford definition, phonetic transcription, and example sentence below the search bar."
    },
    "enable-ai-summary": {
        "type": "checkbox",
        "default": true,
        "description": "Show AI word summary (free, no API key needed)",
        "tooltip": "Shows AI-generated answers and word summaries. Uses Pollinations.ai (free, no key). Add a free Groq key below for a reliable fallback."
    },
    "groq-api-key": {
        "type": "entry",
        "default": "",
        "description": "Groq API key (optional \u2014 fast free fallback AI)",
        "tooltip": "Free key at console.groq.com \u2014 no credit card needed. Used as fallback when Pollinations.ai is down. Leave blank to use Pollinations only."
    },
    "enable-newsletter": {
        "type": "checkbox",
        "default": true,
        "description": "Show AI Newsletter (daily news summary)",
        "tooltip": "Shows an AI-generated summary of today's top news in politics, science, and culture at the top of the Favourites view. Refreshes once per session."
    },
    "show-recent-files": {
        "type": "switch",
        "default": true,
        "description": "Show recently used files",
        "tooltip": "Shows a scrollable row of your most recently opened files at the top of the Favourites view. Click a file to open it."
    },
    "recent-files-count": {
        "type": "spinbutton",
        "default": 10,
        "min": 3,
        "max": 20,
        "step": 1,
        "units": "files",
        "description": "Number of recent files to show",
        "tooltip": "How many recently used files to display in the strip."
    }
}
