#. 5.4->settings-schema.json->hover-peek-delay->units
#. 5.4->settings-schema.json->label-animation-time->units
#. 5.4->settings-schema.json->preview-timeout-show->units
#. 5.4->settings-schema.json->preview-timeout-hide->units
msgid "milliseconds"
msgstr "millisekunder"

#. 4.0->settings-schema.json->fade-animation-time->description
#. 6.0->settings-schema.json->fade-animation-time->description
#. 5.4->settings-schema.json->fade-animation-time->description
msgid "Fade animation effect duration"
msgstr "Varighed af ind-/udtoning"

#. 4.0->settings-schema.json->fade-animation-time->tooltip
#. 6.0->settings-schema.json->fade-animation-time->tooltip
#. 5.4->settings-schema.json->fade-animation-time->tooltip
msgid ""
"This defines the duration of the fade-in/out animation effect. It applies to "
"the Thumbnail menus and the full size window previews"
msgstr ""
"Dette angiver varigheden af ind-/udtoningsanimationseffekten. Det gælder for "
"miniaturemenuerne og vinduesforhåndsvisningerne i fuld størrelse."

#. 4.0->settings-schema.json->hover-peek-delay->description
#. 6.0->settings-schema.json->hover-peek-delay->description
#. 5.4->settings-schema.json->hover-peek-delay->description
msgid "Hover time before showing a full size window preview"
msgstr "Tidsforsinkelse før vinduesforhåndsvisningerne i fuld størrelse vises"

#. 4.0->settings-schema.json->hover-peek-delay->tooltip
#. 6.0->settings-schema.json->hover-peek-delay->tooltip
#. 5.4->settings-schema.json->hover-peek-delay->tooltip
msgid ""
"This defines the mouse hover time before a full size window preview will "
"appear. It applies when hovering over either window list buttons or "
"thumbnail menu items (of course one of the full size window preview options "
"must be enabled for this option to have any effect)"
msgstr ""
"Dette angiver, hvor længe musemarkøren skal holdes over et element, før der "
"vises en vinduesforhåndsvisning i fuld størrelse. Indstillingen gælder, når "
"man holder musen over enten knapperne i vindueslisten eller menupunkterne "
"med miniaturer (en af indstillingerne for forhåndsvisning i fuld størrelse "
"skal naturligvis være aktiveret, for at denne indstilling skal have nogen "
"effekt)."

#. 4.0->settings-schema.json->label-width->units
#. 4.0->settings-schema.json->button-spacing->units
#. 6.0->settings-schema.json->label-width->units
#. 6.0->settings-schema.json->button-spacing->units
#. 5.4->settings-schema.json->label-width->units
#. 5.4->settings-schema.json->button-spacing->units
msgid "pixels"
msgstr "pixels"

#. 4.0->settings-schema.json->label-width->description
#. 6.0->settings-schema.json->label-width->description
#. 5.4->settings-schema.json->label-width->description
msgid "Label width"
msgstr "Etiketbredde"

#. 4.0->settings-schema.json->label-width->tooltip
#. 6.0->settings-schema.json->label-width->tooltip
#. 5.4->settings-schema.json->label-width->tooltip
msgid "This defines the width of the label section of a window list button"
msgstr "Dette definerer bredden på etiketdelen af en vindueslisteknap"

#. 4.0->settings-schema.json->label-animation->description
#. 6.0->settings-schema.json->label-animation->description
#. 5.4->settings-schema.json->label-animation->description
msgid "Animate label"
msgstr "Animér etiket"

#. 4.0->settings-schema.json->label-animation-time->description
#. 6.0->settings-schema.json->label-animation-time->description
#. 5.4->settings-schema.json->label-animation-time->description
msgid "Label animation duration"
msgstr "Varighed af etiketanimation"

#. 4.0->settings-schema.json->number-type->options
#. 6.0->settings-schema.json->number-type->options
#. 5.4->settings-schema.json->number-type->options
msgid "Nothing"
msgstr "Gør intet"

#. 4.0->settings-schema.json->number-type->options
#. 6.0->settings-schema.json->number-type->options
#. 5.4->settings-schema.json->number-type->options
msgid "Application group indicator (…)"
msgstr "Programgruppeindikator (…)"

#. 4.0->settings-schema.json->number-type->options
#. 6.0->settings-schema.json->number-type->options
#. 5.4->settings-schema.json->number-type->options
msgid "Workspace number"
msgstr "Arbejdsområdenummer"

#. 4.0->settings-schema.json->number-type->options
#. 6.0->settings-schema.json->number-type->options
#. 5.4->settings-schema.json->number-type->options
msgid "Monitor number"
msgstr "Skærmnummer"

#. 4.0->settings-schema.json->number-type->options
#. 6.0->settings-schema.json->number-type->options
#. 5.4->settings-schema.json->number-type->options
msgid "Two characters from the window title"
msgstr "To tegn fra vinduestitlen"

#. 4.0->settings-schema.json->number-type->options
#. 6.0->settings-schema.json->number-type->options
#. 5.4->settings-schema.json->number-type->options
msgid "Minimized indicator"
msgstr "Minimeret indikator"

#. 4.0->settings-schema.json->number-type->options
#. 6.0->settings-schema.json->number-type->options
#. 5.4->settings-schema.json->number-type->options
msgid "Pinned indicator"
msgstr "Fastgjort indikator"

#. 4.0->settings-schema.json->number-type->options
#. 6.0->settings-schema.json->number-type->options
#. 5.4->settings-schema.json->number-type->options
msgid "Minimized and pinned indicators"
msgstr "Minimerede og fastgjorte indikatorer"

#. 4.0->settings-schema.json->number-type->description
#. 6.0->settings-schema.json->number-type->description
#. 5.4->settings-schema.json->number-type->description
msgid "Icon overlay label contents"
msgstr "Etiketindhold for ikonoverlejring"

#. 4.0->settings-schema.json->display-number->description
#. 6.0->settings-schema.json->display-number->description
#. 5.4->settings-schema.json->display-number->description
msgid "Only display label when needed"
msgstr "Vis kun etiket, når det er nødvendigt"

#. 4.0->settings-schema.json->display-number->tooltip
#. 6.0->settings-schema.json->display-number->tooltip
#. 5.4->settings-schema.json->display-number->tooltip
msgid ""
"With this option enabled, the icon overlay label will only appear when it is "
"appropriate depending on the label content (i.e. When there are two or more "
"windows in a group, or when the windows workspace or monitor does not match "
"the current one). When this option is disabled the label is always shown"
msgstr ""
"Når denne indstilling er aktiveret, vises ikonoverlejringsteksten kun, når "
"det er relevant i forhold til tekstens indhold (dvs. når der er to eller "
"flere vinduer i en gruppe, eller når vinduernes arbejdsområde eller skærm "
"ikke stemmer overens med det aktuelle). Når denne indstilling er "
"deaktiveret, vises teksten altid."

#. 4.0->settings-schema.json->progress-display-type->options
#. 4.0->settings-schema.json->display-pinned->options
#. 6.0->settings-schema.json->progress-display-type->options
#. 6.0->settings-schema.json->display-pinned->options
#. 5.4->settings-schema.json->progress-display-type->options
#. 5.4->settings-schema.json->display-pinned->options
msgid "Disabled"
msgstr "Deaktiveret"

#. 4.0->settings-schema.json->progress-display-type->options
#. 6.0->settings-schema.json->progress-display-type->options
#. 5.4->settings-schema.json->progress-display-type->options
msgid "Using icon overlay label"
msgstr "Bruger ikonoverlejringsetiket"

#. 4.0->settings-schema.json->progress-display-type->options
#. 6.0->settings-schema.json->progress-display-type->options
#. 5.4->settings-schema.json->progress-display-type->options
msgid "Prepended to button label"
msgstr "Føjes foran knapteksten"

#. 4.0->settings-schema.json->progress-display-type->description
#. 6.0->settings-schema.json->progress-display-type->description
#. 5.4->settings-schema.json->progress-display-type->description
msgid "Display window progress information (%)"
msgstr "Vis vinduesfremdriftoplysninger (5)"

#. 4.0->settings-schema.json->progress-display-type->tooltip
#. 6.0->settings-schema.json->progress-display-type->tooltip
#. 5.4->settings-schema.json->progress-display-type->tooltip
msgid ""
"Controls how a windows progress information is presented on the window list "
"(i.e copying in File Manager, downloading in Firefox, updating in Update "
"Manager, etc.). When on vertical panels the \"Prepended to button label\" "
"option will be ignored and icon overlay will be used in its place."
msgstr ""
"Bestemmer, hvordan statusoplysninger for et vindue vises i vindueslisten (f."
"eks. kopiering i Filhåndtering, download i Firefox, opdatering i "
"Opdateringshåndtering osv.). Når der vises lodrette paneler, ignoreres "
"indstillingen “Føjes foran knapteksten”, og i stedet anvendes en "
"ikonoverlejring."

#. 4.0->settings-schema.json->group-windows->options
#. 6.0->settings-schema.json->group-windows->options
#. 5.4->settings-schema.json->group-windows->options
msgid "Grouped"
msgstr "Grupperet"

#. 4.0->settings-schema.json->group-windows->options
#. 6.0->settings-schema.json->group-windows->options
#. 5.4->settings-schema.json->group-windows->options
msgid "Pooled"
msgstr "Samlet"

#. 4.0->settings-schema.json->group-windows->options
#. 6.0->settings-schema.json->group-windows->options
#. 5.4->settings-schema.json->group-windows->options
msgid "Automatic"
msgstr "Automatisk"

#. 4.0->settings-schema.json->group-windows->options
#. 6.0->settings-schema.json->group-windows->options
#. 5.4->settings-schema.json->group-windows->options
msgid "One to one"
msgstr "En til en"

#. 4.0->settings-schema.json->group-windows->options
#. 6.0->settings-schema.json->group-windows->options
#. 5.4->settings-schema.json->group-windows->options
msgid "Launcher"
msgstr "Programstarter"

#. 4.0->settings-schema.json->group-windows->description
#. 6.0->settings-schema.json->group-windows->description
#. 5.4->settings-schema.json->group-windows->description
msgid "Window list behavior style"
msgstr "Opførsel af vinduesliste"

#. 4.0->settings-schema.json->group-windows->tooltip
#. 6.0->settings-schema.json->group-windows->tooltip
#. 5.4->settings-schema.json->group-windows->tooltip
msgid ""
"Grouped: All windows for an application are managed by one button,\n"
"Pooled: All window list buttons for an application are pooled side by side,\n"
"Automatic: Windows are pooled, and then grouped when space is limited,\n"
"One to one: Each window gets their own button with no forced ordering,\n"
"Launcher: Only pinned buttons are shown, behaves like a panel launcher."
msgstr ""
"Grupperet: Alle vinduer i et program styres af én knap,\n"
"Samlet: Alle vindueslisteknapper for et program er samlet side om side,\n"
"Automatisk: Vinduer samles og grupperes derefter, når pladsen er begrænset,\n"
"En til en: Hvert vindue får sin egen knap uden tvungen rækkefølge,\n"
"Programstarter: Kun fastgjorte knapper vises, opfører sig som en "
"panelprogramstarter."

#. 4.0->settings-schema.json->display-pinned->options
#. 6.0->settings-schema.json->display-pinned->options
#. 5.4->settings-schema.json->display-pinned->options
msgid "Unique for each workspace"
msgstr "Unik for hvert arbejdsområde"

#. 4.0->settings-schema.json->display-pinned->options
#. 6.0->settings-schema.json->display-pinned->options
#. 5.4->settings-schema.json->display-pinned->options
msgid "Common across workspaces"
msgstr "Ens for alle arbejdsområder"

#. 4.0->settings-schema.json->display-pinned->description
#. 6.0->settings-schema.json->display-pinned->description
#. 5.4->settings-schema.json->display-pinned->description
msgid "Pinning of window list buttons"
msgstr "Fastgørelse af vindueslisteknapper"

#. 4.0->settings-schema.json->display-pinned->tooltip
#. 6.0->settings-schema.json->display-pinned->tooltip
#. 5.4->settings-schema.json->display-pinned->tooltip
msgid ""
"Controls whether window list buttons can be pinned, and whether each "
"workspace has a unique set of pinned buttons or one common set shared across "
"all workspaces. When in \"Common across workspaces\" mode the order of the "
"pinned buttons is also maintained across workspaces."
msgstr ""
"Styrer, om vindueslisteknapper kan fastgøres, og om hvert arbejdsområde har "
"et unikt sæt af fastgjorte knapper eller et fælles sæt, der deles på tværs "
"af alle arbejdsområder. I tilstanden “Ens for alle arbejdsområder” bevares "
"rækkefølgen af de fastgjorte knapper også på tværs af arbejdsområder."

#. 4.0->settings-schema.json->synchronize-pinned->description
#. 6.0->settings-schema.json->synchronize-pinned->description
#. 5.4->settings-schema.json->synchronize-pinned->description
msgid "Synchronize launcher buttons across all workspaces"
msgstr "Synkronisérr programstarterknapper på tværs af alle arbejdsområder"

#. 4.0->settings-schema.json->synchronize-pinned->tooltip
#. 6.0->settings-schema.json->synchronize-pinned->tooltip
#. 5.4->settings-schema.json->synchronize-pinned->tooltip
msgid ""
"If enabled, the number and order of launcher buttons on the panel will be "
"synchronized across all workspaces."
msgstr ""
"Hvis aktiveret, synkroniseres antallet og rækkefølgen af "
"programstarterknapper på panelet på tværs af alle arbejdsområder."

#. 4.0->settings-schema.json->show-windows-for-current-monitor->description
#. 6.0->settings-schema.json->show-windows-for-current-monitor->description
#. 5.4->settings-schema.json->show-windows-for-current-monitor->description
msgid "Only show windows on the same monitor"
msgstr "Vis kun vinduer på den samme skærm"

#. 4.0->settings-schema.json->show-windows-for-current-monitor->tooltip
#. 6.0->settings-schema.json->show-windows-for-current-monitor->tooltip
#. 5.4->settings-schema.json->show-windows-for-current-monitor->tooltip
msgid ""
"If enabled, this applet instance only manages windows\n"
"that are displayed on the same monitor"
msgstr ""
"Hvis aktiveret håndterer panelprogrammet kun vinduer,\n"
"som vises på den samme skærm"

#. 4.0->settings-schema.json->show-windows-for-all-workspaces->description
#. 6.0->settings-schema.json->show-windows-for-all-workspaces->description
#. 5.4->settings-schema.json->show-windows-for-all-workspaces->description
msgid "Include windows from all workspaces"
msgstr "Medtag vinduer fra alle arbejdsområder"

#. 4.0->settings-schema.json->remember-button-order->description
#. 6.0->settings-schema.json->remember-button-order->description
#. 5.4->settings-schema.json->remember-button-order->description
msgid "Allow prioritizing window list button order"
msgstr "Tillad prioritering af knaprækkefølgen i vindueslisten"

#. 4.0->settings-schema.json->remember-button-order->tooltip
#. 6.0->settings-schema.json->remember-button-order->tooltip
#. 5.4->settings-schema.json->remember-button-order->tooltip
msgid ""
"Enabling this option makes it easy for you to control where your favorite "
"applications will appear on the window list. This is achieved by maintaining "
"a persistent position priority order for applications. New Window list "
"buttons for applications with priority will appear in priority order and "
"ahead of applications without priority. Using drag-and-drop will "
"automatically add to and reorder the priority list. The \"Prioritize window "
"list position\" context menu option allows you to add and remove an "
"application from the priority list."
msgstr ""
"Når du aktiverer denne indstilling, kan du nemt styre, hvor dine foretrukne "
"programmer skal vises i vindueslisten. Dette opnås ved at opretholde en fast "
"prioriteringsrækkefølge for programmerne. Knapperne på listen over nye "
"vinduer for programmer med prioritet vises i prioriteringsrækkefølge og "
"foran programmer uden prioritet. Ved at bruge træk-og-slip tilføjes "
"programmer automatisk til prioritetslisten, og rækkefølgen ændres. Med "
"kontekstmenupunktet “Prioritér vindueslisteplacering” kan du tilføje og "
"fjerne et program fra prioritetslisten."

#. 4.0->settings-schema.json->show-tooltips->description
#. 6.0->settings-schema.json->show-tooltips->description
#. 5.4->settings-schema.json->show-tooltips->description
msgid "Show tooltips for window list buttons"
msgstr "Vis værktøjstip til vindueslisteknapper"

#. 4.0->settings-schema.json->show-tooltips->tooltip
#. 6.0->settings-schema.json->show-tooltips->tooltip
#. 5.4->settings-schema.json->show-tooltips->tooltip
msgid ""
"Enable to show tooltips using window title or application name when hovering "
"over window list buttons"
msgstr ""
"Aktivér for at vise værktøjstips med vinduestitel eller programnavn, når man "
"holder musen over vindueslisteknapper"

#. 4.0->settings-schema.json->show-tooltip-hotkeys->description
#. 6.0->settings-schema.json->show-tooltip-hotkeys->description
#. 5.4->settings-schema.json->show-tooltip-hotkeys->description
msgid "Show hotkeys in the window list button tooltips"
msgstr "Vis genvejstaster i værktøjstippene til vindueslisteknapper"

#. 4.0->settings-schema.json->show-tooltip-hotkeys->tooltip
#. 6.0->settings-schema.json->show-tooltip-hotkeys->tooltip
#. 5.4->settings-schema.json->show-tooltip-hotkeys->tooltip
msgid ""
"Enable to show window activation hotkeys in the window list button tooltips"
msgstr ""
"Aktivér for at vise værktøjstips med genvejstaster til vinduesaktivering"

#. 4.0->settings-schema.json->hide-panel-apps->description
#. 6.0->settings-schema.json->hide-panel-apps->description
#. 5.4->settings-schema.json->hide-panel-apps->description
msgid ""
"Hide buttons for applications on 'Launcher' instances of CassiaWindowList"
msgstr ""
"Skjul knapper for programmer i “Porgramstarter”-forekomster af "
"CassiaVinduesliste"

#. 4.0->settings-schema.json->hide-panel-apps->tooltip
#. 6.0->settings-schema.json->hide-panel-apps->tooltip
#. 5.4->settings-schema.json->hide-panel-apps->tooltip
msgid ""
"When enabled, windows for applications with pinned buttons on other "
"'Launcher' mode instances of the CassiaWindowList applet will not show up in "
"this window list"
msgstr ""
"Når denne indstilling er aktiveret, vises vinduer for programmer med "
"fastgjorte knapper i andre forekomster af CassiaVinduesliste-panelprogrammet "
"i “Programstarter”-tilstand ikke i denne vinduesliste"

#. 4.0->settings-schema.json->button-spacing->description
#. 6.0->settings-schema.json->button-spacing->description
#. 5.4->settings-schema.json->button-spacing->description
msgid "Spacing between buttons"
msgstr "Mellemrum mellem knapper"

#. 4.0->settings-schema.json->button-spacing->tooltip
#. 6.0->settings-schema.json->button-spacing->tooltip
#. 5.4->settings-schema.json->button-spacing->tooltip
msgid ""
"This defines the spacing between the buttons, the value will be divided in "
"half and added to the left of the icon and to the right of the label on "
"horizontal panels or to the top and button of the icon on vertical panels"
msgstr ""
"Dette angiver afstanden mellem knapperne. Værdien deles i to og lægges til "
"venstre for ikonet og til højre for teksten på vandrette paneler, eller "
"øverst og nederst på ikonet på lodrette paneler."

#. 4.0->settings-schema.json->hover-peek-windowlist->description
#. 6.0->settings-schema.json->hover-peek-windowlist->description
#. 5.4->settings-schema.json->hover-peek-windowlist->description
msgid "Show a full size window preview when hovering over a button"
msgstr ""
"Vis vinduesforhåndsvisning i fuld størrelse, når musen holdes over en knap"

#. 4.0->settings-schema.json->hover-peek-windowlist->tooltip
#. 6.0->settings-schema.json->hover-peek-windowlist->tooltip
#. 5.4->settings-schema.json->hover-peek-windowlist->tooltip
msgid ""
"If enabled, a full size preview window will appear when the mouse pointer is "
"hovering over a window list button. The delay before the preview appears is "
"controlled by an option under the Advanced tab"
msgstr ""
"Hvis denne funktion er aktiveret, vises et forhåndsvisningsvindue i fuld "
"størrelse, når musemarkøren holdes over en knap i vindueslisten. Ventetiden, "
"før forhåndsvisningen vises, styres via en indstilling under fanebladet "
"“Avanceret”."

#. 4.0->settings-schema.json->no-click-activate->description
#. 6.0->settings-schema.json->no-click-activate->description
#. 5.4->settings-schema.json->no-click-activate->description
msgid "Automatic focus change when leaving the panel"
msgstr "Automatisk fokusskifte når panelet forlades"

#. 4.0->settings-schema.json->no-click-activate->tooltip
#. 6.0->settings-schema.json->no-click-activate->tooltip
#. 5.4->settings-schema.json->no-click-activate->tooltip
msgid ""
"If enabled, the current window for a window list button will get the focus "
"when the mouse pointer leaves the panel. Leaving the window list with Ctrl "
"or Shift held or while remaining on the panel will leave the focus "
"unchanged. This option is typically used in conjunction with the preview "
"hovering option above."
msgstr ""
"Hvis denne indstilling er aktiveret, får det aktuelle vindue for en knap i "
"vindueslisten fokus, når musemarkøren forlader panelet. Hvis du forlader "
"vindueslisten med Ctrl- eller Skift-tasten nede, eller mens du forbliver på "
"panelet, forbliver fokus uændret. Denne indstilling bruges typisk sammen med "
"indstillingen for forhåndsvisning ved musemarkørens placering ovenfor."

#. 4.0->settings-schema.json->menu-show-on-hover->description
#. 6.0->settings-schema.json->menu-show-on-hover->description
#. 5.4->settings-schema.json->menu-show-on-hover->description
msgid "Show on hover"
msgstr "Vis, når markøren er over"

#. 4.0->settings-schema.json->menu-show-on-hover->tooltip
#. 6.0->settings-schema.json->menu-show-on-hover->tooltip
#. 5.4->settings-schema.json->menu-show-on-hover->tooltip
msgid ""
"If enabled, a popup menu with a list of current windows will show when "
"hovering"
msgstr ""
"Hvis aktiveret vil en pop op-menu med en liste over aktuelle vinduer blive "
"vist, når markøren holdes over"

#. 4.0->settings-schema.json->show-previews->description
#. 6.0->settings-schema.json->show-previews->description
#. 5.4->settings-schema.json->show-previews->description
msgid "Show window thumbnails in the popup window list menu"
msgstr "Vis vinduesminiaturer i vindueslistens pop op-menu"

#. 4.0->settings-schema.json->show-previews->tooltip
#. 6.0->settings-schema.json->show-previews->tooltip
#. 5.4->settings-schema.json->show-previews->tooltip
msgid ""
"If enabled, the popup menu will show window thumbnails,\n"
"otherwise the menu will only show window titles\n"
"(Always disabled when running Cinnamon in Software Rendering Mode)"
msgstr ""
"Hvis aktiveret, vil popup-menuen vise vinduesminiaturer,\n"
"ellers vil menuen kun vise vinduestitler\n"
"(Altid deaktiveret, når du kører Cinnamon i Softwaregengivelsestilstand)"

#. 4.0->settings-schema.json->number-of-unshrunk-previews->options
#. 6.0->settings-schema.json->number-of-unshrunk-previews->options
#. 5.4->settings-schema.json->number-of-unshrunk-previews->options
msgid "Extra large"
msgstr "Ekstra stor"

#. 4.0->settings-schema.json->number-of-unshrunk-previews->options
#. 6.0->settings-schema.json->number-of-unshrunk-previews->options
#. 5.4->settings-schema.json->number-of-unshrunk-previews->options
msgid "Large"
msgstr "Stor"

