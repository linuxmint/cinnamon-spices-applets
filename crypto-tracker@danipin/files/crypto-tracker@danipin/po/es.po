# The following strings are extracted from metadata.json:
msgctxt "name"
msgid "Crypto Tracker"
msgstr "Rastreador de Criptomonedas"

msgctxt "description"
msgid "Displays real-time cryptocurrency prices on the panel (via CoinGecko API)."
msgstr "Muestra los precios de las criptomonedas en tiempo real en el panel (a través de la API de CoinGecko)."

# The following strings are extracted from settings-schema.json:
msgid "Metric 1 (Primary)"
msgstr "Métrica 1 (Principal)"

msgid "Metric 2"
msgstr "Métrica 2"

msgid "Metric 3"
msgstr "Métrica 3"

msgid "Applet General Settings"
msgstr "Configuración General del Applet"

msgid "Display and Activation"
msgstr "Pantalla y Activación"

msgid "Data Source (API)"
msgstr "Fuente de Datos (API)"

msgid "Color Settings"
msgstr "Configuración de Color"

msgid "Changes will activate on the next API update interval."
msgstr "Los cambios se activarán en el próximo intervalo de actualización de la API."

msgid "General Applet Settings"
msgstr "Configuración General del Applet"

msgid "Update Interval"
msgstr "Intervalo de Actualización"

msgid "How often prices are fetched from CoinGecko."
msgstr "Frecuencia con la que se obtienen los precios de CoinGecko."

msgid "15 Seconds (Minimum)"
msgstr "15 Segundos (Mínimo)"

msgid "30 Seconds"
msgstr "30 Segundos"

msgid "60 Seconds (1 Minute)"
msgstr "60 Segundos (1 Minuto)"

msgid "120 Seconds (2 Minutes)"
msgstr "120 Segundos (2 Minutos)"

msgid "300 Seconds (5 Minutes)"
msgstr "300 Segundos (5 Minutos)"

msgid "Color the Arrow Only"
msgstr "Colorear solo la flecha"

msgid "If active, the price text remains white."
msgstr "Si está activo, el texto del precio permanece en blanco."

msgid "Show Currency Symbol (e.g. $ or €)"
msgstr "Mostrar Símbolo de Moneda (p. ej., $ o €)"

msgid "Replaces the currency code with the symbol."
msgstr "Reemplaza el código de moneda con el símbolo."

msgid "Enabled"
msgstr "Activado"

msgid "Toggles the display of this metric on/off."
msgstr "Activa/desactiva la visualización de esta métrica."

msgid "Currency ID (CoinGecko)"
msgstr "ID de la Criptomoneda (CoinGecko)"

msgid "Select the cryptocurrency from the top list."
msgstr "Seleccione la criptomoneda de la lista superior."

msgid "The value in brackets (e.g. BTC) is the default symbol displayed on the panel."
msgstr "El valor entre corchetes (p. ej., BTC) es el símbolo predeterminado que se muestra en el panel."

msgid "Bitcoin (BTC)"
msgstr "Bitcoin (BTC)"

msgid "Ethereum (ETH)"
msgstr "Ethereum (ETH)"

msgid "Cardano (ADA)"
msgstr "Cardano (ADA)"

msgid "Solana (SOL)"
msgstr "Solana (SOL)"

msgid "Polkadot (DOT)"
msgstr "Polkadot (DOT)"

msgid "Custom Currency ID"
msgstr "ID de Moneda Personalizada"

msgid "CoinGecko ID (e.g. 'litecoin')"
msgstr "ID de CoinGecko (p. ej., 'litecoin')"

msgid "Enter the exact CoinGecko ID. This field overrides the dropdown selection and is preferred for unlisted coins."
msgstr "Ingrese la ID exacta de CoinGecko. Este campo anula la selección desplegable y se prefiere para monedas no listadas."

msgid "Comparison Currency"
msgstr "Moneda de Comparación"

msgid "Select the currency for the price comparison."
msgstr "Seleccione la moneda para la comparación de precios."

msgid "The API call uses the code in brackets (e.g. USD)."
msgstr "La llamada a la API utiliza el código entre corchetes (p. ej., USD)."

msgid "US Dollar (USD)"
msgstr "Dólar estadounidense (USD)"

msgid "Euro (EUR)"
msgstr "Euro (EUR)"

msgid "Canadian Dollar (CAD)"
msgstr "Dólar canadiense (CAD)"

msgid "British Pound (GBP)"
msgstr "Libra esterlina (GBP)"

msgid "Japanese Yen (JPY)"
msgstr "Yen japonés (JPY)"

msgid "Swiss Franc (CHF)"
msgstr "Franco suizo (CHF)"

msgid "Australian Dollar (AUD)"
msgstr "Dólar australiano (AUD)"

msgid "Display Symbol"
msgstr "Símbolo de Visualización"

msgid "The symbol displayed on the panel (e.g. BTC)."
msgstr "El símbolo que se muestra en el panel (p. ej., BTC)."

msgid "Color for Rising Price (▲)"
msgstr "Color para Precio en Aumento (▲)"

msgid "Select the color for positive price movement."
msgstr "Seleccione el color para el movimiento positivo del precio."

msgid "Color for Falling Price (▼)"
msgstr "Color para Precio en Caída (▼)"

msgid "Select the color for negative price movement."
msgstr "Seleccione el color para el movimiento negativo del precio."

# The following strings are extracted from applet.js:
msgid "Loading..."
msgstr "Cargando..."

msgid "24H Price Change (%)"
msgstr "Cambio de Precio en 24H (%)"

msgid "Waiting..."
msgstr "Esperando..."

msgid "No metrics enabled. Please enable them in settings."
msgstr "No hay métricas activadas. Por favor, actívelas en la configuración."
