msgstr ""

#. settings-schema.json->sec_tools->title
msgid "Run a command"
msgstr "Chạy lệnh"

#. settings-schema.json->sec_po->title
msgid "Push notifications (Pushover)"
msgstr "Thông báo đẩy (Pushover)"

#. settings-schema.json->sec_po_messages->title
msgid "Notification text"
msgstr "Nội dung thông báo"

#. settings-schema.json->sec_po_alerts->title
