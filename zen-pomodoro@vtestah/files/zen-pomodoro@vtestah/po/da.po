msgstr "Lydstyrke for tikkelyden (0 = lydløst)."

#. settings-schema.json->break_sound->description
msgid "Play Break Sound"
msgstr "Afspil pauselyd"

#. settings-schema.json->break_sound->tooltip
msgid "Play a sound when a break begins."
msgstr "Afspil en lyd, når en pause begynder."

#. settings-schema.json->break_sound_file->description
msgid "Break Sound File"
msgstr "Pauselydfil"

#. settings-schema.json->break_sound_file->tooltip
msgid "Sound file played when a break begins."
msgstr "Lydfil der afspilles, når en pause begynder."

#. settings-schema.json->break_sound_volume->tooltip
msgid "Volume of the break sound (0 = silent)."
msgstr "Lydstyrke for pauselyden (0 = lydløst)."

#. settings-schema.json->warn_sound->description
msgid "Play Warn Sound"
msgstr "Afspil advarselslydfil"

#. settings-schema.json->warn_sound->tooltip
msgid "Play a warning sound shortly before a focus block ends."
msgstr "Afspil en advarselslyd kort før en fokusblok slutter."

#. settings-schema.json->warn_sound_delay->description
msgid "Warn Delay (in secs):"
msgstr "Advarselsforsinkelse (i sekunder):"

#. settings-schema.json->warn_sound_delay->tooltip
msgid "How many seconds before the end the warning sound plays."
msgstr "Hvor mange sekunder før slutningen advarselslyden afspilles."

#. settings-schema.json->warn_sound_file->description
msgid "Warn Sound File"
msgstr "Advarselslydfil"

#. settings-schema.json->warn_sound_file->tooltip
msgid "Sound file used for the warning."
msgstr "Lydfil der bruges til advarslen."

#. settings-schema.json->warn_sound_volume->tooltip
msgid "Volume of the warning sound (0 = silent)."
msgstr "Lydstyrke for advarselslyden (0 = lydløst)."

#. settings-schema.json->start_sound->description
msgid "Play Start Sound"
msgstr "Afspil startlyd"

#. settings-schema.json->start_sound->tooltip
msgid "Play a sound when a focus block starts."
msgstr "Afspil en lyd, når en fokusblok starter."

#. settings-schema.json->start_sound_file->description
msgid "Start Sound File"
msgstr "Startlydfil"

#. settings-schema.json->start_sound_file->tooltip
msgid "Sound file played when focus starts."
msgstr "Lydfil der afspilles, når fokus starter."

#. settings-schema.json->start_sound_volume->tooltip
msgid "Volume of the start sound (0 = silent)."
msgstr "Lydstyrke for startlyden (0 = lydløst)."

#. settings-schema.json->interval_chime->description
msgid "Play a chime at a regular interval during focus"
msgstr "Afspil en klokketone med jævne mellemrum under fokus"

#. settings-schema.json->interval_chime->tooltip
msgid "Play a sound at a fixed interval during focus to mark time passing."
msgstr ""
"Afspil en lyd med faste mellemrum under fokus for at markere tidens gang."

#. settings-schema.json->interval_chime_seconds->description
msgid "Chime interval (seconds):"
msgstr "Klokketoneinterval (sekunder):"

#. settings-schema.json->interval_chime_seconds->tooltip
msgid "Seconds between chimes during focus."
msgstr "Sekunder mellem klokketoner under fokus."

#. settings-schema.json->interval_chime_file->description
msgid "Chime sound file"
msgstr "Lydfil til klokketone"

#. settings-schema.json->interval_chime_file->tooltip
msgid "Sound file used for the interval chime."
msgstr "Lydfil der bruges til intervalklokketonen."

#. settings-schema.json->interval_chime_volume->description
msgid "Chime volume:"
msgstr "Klokketonelydstyrke:"

#. settings-schema.json->interval_chime_volume->tooltip
msgid "Volume of the interval chime (0 = silent)."
msgstr "Lydstyrke for intervalklokketonen (0 = lydløst)."

