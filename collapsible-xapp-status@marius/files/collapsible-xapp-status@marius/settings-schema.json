{
    "hidden-apps": {
        "type": "generic",
        "default": []
    },
    "known-apps": {
        "type": "generic",
        "default": []
    },
    "expand-mode": {
        "type": "combobox",
        "default": "popup",
        "options": {
            "Popup above the arrow (like Windows)": "popup",
            "Expand inside the panel": "inline"
        },
        "description": "How hidden icons are revealed"
    },
    "hide-new-icons": {
        "type": "checkbox",
        "default": true,
        "description": "Automatically hide icons of new applications (like Windows)"
    },
    "max-icon-size": {
        "type": "spinbutton",
        "default": 20,
        "min": 0,
        "max": 64,
        "step": 2,
        "units": "px",
        "description": "Maximum size of app icons (0 = follow panel size)"
    },
    "autocollapse-delay": {
        "type": "spinbutton",
        "default": 10,
        "min": 0,
        "max": 300,
        "step": 1,
        "units": "seconds",
        "description": "Collapse hidden icons again after this many seconds (0 = stay expanded)"
    },
    "collapse-on-click": {
        "type": "checkbox",
        "default": true,
        "description": "Collapse after clicking a hidden icon"
    }
}
