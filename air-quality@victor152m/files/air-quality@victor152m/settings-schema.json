{
  "layout": {
    "type": "layout",
    "pages": ["location"],

    "location": {
      "type": "page",
      "title": "Location",
      "sections": ["location_main"]
    },

    "location_main": {
      "type": "section",
      "title": "Coordinates",
      "keys": ["latitude", "longitude"]
    }
  },

  "latitude": {
    "type": "spinbutton",
    "default": 44.4,
    "min": -90,
    "max": 90,
    "step": 0.01,
    "description": "Latitude"
  },

  "longitude": {
    "type": "spinbutton",
    "default": 26.09,
    "min": -180,
    "max": 180,
    "step": 0.01,
    "description": "Longitude"
  }
}