#. metadata.json->name
#: applet.js:104
msgid "Multi-Row Panel Launchers"
msgstr "Lanzadores de paneles de varias filas"

#. metadata.json->description
msgid "Panel launcher applet that wraps icons into multiple rows using FlowLayout"
msgstr "Applet de panel de inicio que organiza los iconos en varias filas utilizando FlowLayout"

#. settings-schema.json->section1->description
msgid "Behavior"
msgstr "Comportamiento"

#. settings-schema.json->allow-dragging->description
msgid "Allow dragging of launchers"
msgstr "Permitir arrastrar lanzadores"

#. settings-schema.json->section-multirow->description
msgid "Multi-Row Layout"
msgstr "Diseño de varias filas"

#. settings-schema.json->max-rows->units
msgid "rows"
msgstr "filas"

#. settings-schema.json->max-rows->description
msgid "Maximum rows for launcher icons (1 = single row)"
msgstr "Número máximo de filas para los iconos del lanzador (1 = una sola fila)"

#. settings-schema.json->section-appearance->description
msgid "Appearance"
msgstr "Apariencia"

#. settings-schema.json->icon-size-override->units
#. settings-schema.json->max-width->units
msgid "pixels"
msgstr "pixeles"

#. settings-schema.json->icon-size-override->description
msgid "Icon size override (0 = auto-scale to row height)"
msgstr "Ajustar el tamaño de los iconos (0 = ajustar automáticamente a la altura de la fila)"

#. settings-schema.json->max-width->description
msgid "Maximum width for launcher area (0 = no limit)"
msgstr "Ancho máximo del área del lanzador (0 = sin límite)"

#. settings-schema.json->section-troubleshooting->description
msgid "Troubleshooting"
msgstr "Solución de problemas"

#. settings-schema.json->debug-logging->description
msgid "Write layout diagnostics to the log (Looking Glass / ~/.xsession-errors)"
msgstr "Escribir los diagnósticos de disposición en el registro (Looking Glass / ~/.xsession-errors)"
