{
    "head-general": {
        "type": "header",
        "description": "General"
    },
    "min-brightness": {
        "type": "scale",
        "default": 10,
        "min": 1,
        "max": 50,
        "step": 1,
        "description": "Brillo mínimo permitido (%)",
        "tooltip": "Suelo del slider de brillo, para no dejar la pantalla totalmente negra."
    },

    "head-modes": {
        "type": "header",
        "description": "Modos (nombre, brillo %, temperatura K)"
    },
    "modes": {
        "type": "list",
        "columns": [
            { "id": "name", "title": "Nombre", "type": "string" },
            { "id": "brightness", "title": "Brillo (%)", "type": "integer", "min": 1, "max": 100, "step": 1, "default": 80, "align": 0.5 },
            { "id": "temperature", "title": "Temperatura (K)", "type": "integer", "min": 2500, "max": 6500, "step": 100, "default": 5000, "align": 0.5 }
        ],
        "default": [
            { "name": "Día", "brightness": 100, "temperature": 6500 },
            { "name": "Noche", "brightness": 60, "temperature": 3400 }
        ]
    },

    "head-auto": {
        "type": "header",
        "description": "Automático día/noche (horario fijo)"
    },
    "auto-night": {
        "type": "switch",
        "default": false,
        "description": "Aplicar el modo de noche a una hora fija",
        "tooltip": "Cambia de modo a horas fijas. No usa el Night Light de Cinnamon; apágalo para que no peleen por el color."
    },
    "night-mode": {
        "type": "combobox",
        "default": "Noche",
        "description": "Modo de noche",
        "options": { "Día": "Día", "Noche": "Noche" },
        "dependency": "auto-night"
    },
    "night-hour": {
        "type": "spinbutton",
        "default": 21, "min": 0, "max": 23, "step": 1, "units": "h",
        "description": "Hora de noche",
        "dependency": "auto-night"
    },
    "night-minute": {
        "type": "spinbutton",
        "default": 0, "min": 0, "max": 59, "step": 5, "units": "min",
        "description": "Minuto de noche",
        "dependency": "auto-night"
    },
    "auto-day": {
        "type": "switch",
        "default": false,
        "description": "Aplicar el modo de día a una hora fija"
    },
    "day-mode": {
        "type": "combobox",
        "default": "Día",
        "description": "Modo de día",
        "options": { "Día": "Día", "Noche": "Noche" },
        "dependency": "auto-day"
    },
    "day-hour": {
        "type": "spinbutton",
        "default": 8, "min": 0, "max": 23, "step": 1, "units": "h",
        "description": "Hora de día",
        "dependency": "auto-day"
    },
    "day-minute": {
        "type": "spinbutton",
        "default": 0, "min": 0, "max": 59, "step": 5, "units": "min",
        "description": "Minuto de día",
        "dependency": "auto-day"
    },

    "brightness": {
        "type": "generic",
        "default": 100
    },
    "temperature": {
        "type": "generic",
        "default": 6500
    }
}
