{
    "refresh-interval": {
        "type": "spinbutton",
        "default": 1200,
        "min": 100,
        "max": 5000,
        "step": 100,
        "units": "ms",
        "description": "Frecuencia de actualización"
    },
    "show-cpu": {
        "type": "switch",
        "default": true,
        "description": "Mostrar uso de CPU"
    },
    "show-ram": {
        "type": "switch",
        "default": true,
        "description": "Mostrar uso de RAM"
    },
    "show-swap": {
        "type": "switch",
        "default": true,
        "description": "Mostrar uso de memoria SWAP"
    },
    "show-gpu": {
        "type": "switch",
        "default": true,
        "description": "Mostrar porcentaje de la GPU"
    },
    "show-vram": {
        "type": "switch",
        "default": true,
        "description": "Mostrar memoria de video (VRAM)"
    }
}
