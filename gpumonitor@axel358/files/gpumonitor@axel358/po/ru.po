#: applet.js:62
msgid "Launch Radeontop"
msgstr "Запустить Radeontop"

#. metadata.json->name
msgid "AMD GPU Monitor"
msgstr "Монитор AMD GPU"

#. metadata.json->description
msgid "Monitor AMD GPU statistics, requires radeontop"
msgstr "Мониторинг статистики AMD GPU, требуется radeontop"

#. settings-schema.json->head->description
msgid "Settings"
msgstr "Настройки"

#. settings-schema.json->display-style->description
msgid "Display style"
msgstr "Стиль отображения"

#. settings-schema.json->display-style->options
msgid "Column"
msgstr "Столбец"

#. settings-schema.json->display-style->options
msgid "Side by side"
sgstr "Бок о бок"

#. settings-schema.json->display-style->options
msgid "GPU only"
msgstr "Только GPU"

#. settings-schema.json->display-style->options
msgid "VRAM only"
msgstr "Только VRAM"

#. settings-schema.json->use-compact-label->description
msgid "Use compact label style"
msgstr "Использовать компактные метки"

#. settings-schema.json->use-compact-label->tooltip
msgid "Show only the first character of each label. Example: G for GPU"
msgstr "Показывать только первый символ каждой метки. Например: G для GPU"

#. settings-schema.json->refresh-interval->units
msgid "milliseconds"
msgstr "миллисекунды"

#. settings-schema.json->refresh-interval->description
msgid "Refresh interval"
msgstr "Интервал обновления"

#. settings-schema.json->refresh-interval->tooltip
msgid "Time between data refeshes"
msgstr "Время между обновлениями данных"

#. settings-schema.json->decimal-places->description
msgid "Decimal places"
msgstr "Знаков после запятой"

#. settings-schema.json->decimal-places->tooltip
msgid "Number of decimal places to show"
msgstr "Количество отображаемых знаков после запятой"

#. settings-schema.json->select-gpu->description
msgid "Select GPU (bus no.)"
msgstr "Выберите GPU (номер шины)"

#. settings-schema.json->select-gpu->options
msgid "Loading..."
msgstr "Загрузка..."

#. settings-schema.json->select-gpu->tooltip
msgid "Use 'lshw -C display' for more info"
msgstr "Используйте «lshw -C display» для получения дополнительной информации"

#. settings-schema.json->font-size->description
msgid "Font size"
msgstr "Размер шрифта"

#. settings-schema.json->font-size->tooltip
msgid "Label font size"
msgstr "Размер шрифта меток"
