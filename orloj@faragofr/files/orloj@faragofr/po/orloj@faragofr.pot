#. metadata.json->name
msgid "Orloj"
msgstr ""

#. metadata.json->description
msgid "Prague-style astronomical clock applet"
msgstr ""

#. settings-schema.json->use-geoip->description
msgid "Automatic location (GeoIP)"
msgstr ""

#. settings-schema.json->use-geoip->tooltip
msgid ""
"Determine location from your IP address (city-level accuracy, uses ip-api."
"com over HTTP). Falls back to the manual coordinates below when offline."
msgstr ""

#. settings-schema.json->latitude->description
msgid "Latitude (decimal degrees, north positive)"
msgstr ""

#. settings-schema.json->latitude->tooltip
msgid "Your geographic latitude in decimal degrees, e.g. 50.0875 for Prague"
msgstr ""

#. settings-schema.json->longitude->description
msgid "Longitude (decimal degrees, east positive)"
msgstr ""

#. settings-schema.json->longitude->tooltip
msgid "Your geographic longitude in decimal degrees, e.g. 14.4214 for Prague"
msgstr ""

#. settings-schema.json->use-lst->description
msgid "Use Local Sidereal Time instead of civil time"
msgstr ""

#. settings-schema.json->use-lst->tooltip
msgid ""
"Show local sidereal time in the dial center (the original behavior). When "
"unchecked, the dial center shows civil time and the time zone options below "
"apply to all displayed times."
msgstr ""

#. settings-schema.json->use-auto-timezone->description
msgid "Automatic time zone (system)"
msgstr ""

#. settings-schema.json->use-auto-timezone->tooltip
msgid ""
"Use the system time zone for all displayed times. Uncheck to pick a time "
"zone manually."
msgstr ""

#. settings-schema.json->timezone->description
msgid "Time zone"
msgstr ""

#. settings-schema.json->timezone->tooltip
msgid ""
"All times shown by the applet (panel and dial) use this time zone. The list "
"is filled from the system time zone database at startup."
msgstr ""

#. settings-schema.json->timezone->options
msgid "UTC"
msgstr ""

#. settings-schema.json->show-sunrise->description
msgid "Show the sun's next rise/set in the panel"
msgstr ""

#. settings-schema.json->show-both-sun->description
msgid "Always show both sunset and sunrise"
msgstr ""

#. settings-schema.json->show-both-sun->tooltip
msgid ""
"Show the sun's rise and set stacked in two lines instead of only the soonest "
"event."
msgstr ""

#. settings-schema.json->show-moonrise->description
msgid "Show the moon's next rise/set in the panel"
msgstr ""

#. settings-schema.json->show-both-moon->description
msgid "Always show both moonset and moonrise"
msgstr ""

#. settings-schema.json->show-both-moon->tooltip
msgid ""
"Show the moon's rise and set stacked in two lines instead of only the "
"soonest event."
msgstr ""

#. settings-schema.json->show-moon-phase->description
msgid "Show moon phase in the panel"
msgstr ""

#. settings-schema.json->show-moon-phase->tooltip
msgid ""
"Schematic moon disk with percent illumination and phase angle (0° new, 90° "
"first quarter, 180° full, 270° last quarter), left of the rise/set times."
msgstr ""

#. settings-schema.json->refresh-seconds->units
msgid "seconds"
msgstr ""

#. settings-schema.json->refresh-seconds->description
msgid "Refresh interval"
msgstr ""

#. settings-schema.json->accent-color->description
msgid "Accent color"
msgstr ""

#. settings-schema.json->foreground-color->description
msgid "Foreground color (text, hands, glyphs)"
msgstr ""

#. settings-schema.json->background-color->description
msgid "Background color"
msgstr ""

#. settings-schema.json->dial-size->units
msgid "pixels"
msgstr ""

#. settings-schema.json->dial-size->description
msgid "Dial size"
msgstr ""

#. settings-schema.json->dial-size->tooltip
msgid "Diameter of the dial in the popup; larger values improve readability"
msgstr ""
