#. applet.js:48
msgid "Suspend"
msgstr "Hviletilstand"

#. metadata.json->description
msgid "Immediately suspends the computer"
msgstr "Sætter øjeblikkeligt computeren i hviletilstand"

#. metadata.json->name
msgid "Suspend computer"
msgstr "Sæt computeren i hviletilstand"

#. settings-schema.json->suspend-header->description
msgid "Suspend computer settings"
msgstr "Indstillinger for hviletilstand"

#. settings-schema.json->suspend-on-double-click->description
msgid "Double-click to suspend"
msgstr "Dobbeltklik for at sætte i hviletilstand"

#. settings-schema.json->suspend-on-double-click->tooltip
msgid ""
"When enabled, a double-click will suspend the computer, otherwise the "
"computer will suspend on a single click."
msgstr ""
"Når aktiveret vil et dobbeltklik sætte computeren i hviletilstand; ellers "
"sættes computeren i hviletilstand med et enkelt klik."

#. settings-schema.json->count-down->description
msgid "Use a count down before suspending"
msgstr "Anvend nedtælling inden hviletilstand"

#. settings-schema.json->count-down->tooltip
msgid ""
"When enabled, a count down will occurs before suspending the computer.\n"
"Clicking again during the count down will cancel the suspend."
msgstr ""
"Når denne funktion er aktiveret, vises der en nedtælling, inden computeren "
"sættes i hviletilstand.\n"
"Hvis du klikker igen under nedtællingen, afbrydes overgangen til "
"hviletilstand."

#. settings-schema.json->count-down-duration->units
msgid "seconds"
msgstr "sekunder"

#. settings-schema.json->count-down-duration->description
msgid "Count down duration"
msgstr "Længde på nedtælling"

#. settings-schema.json->ctrl-override-countdown->description
msgid "Ctrl+Click to override the count down and suspend immediately"
msgstr ""
"Ctrl-klik for at springe nedtælling over og sæt i hviletilstand med det "
"samme"

#. settings-schema.json->ctrl-override-countdown->tooltip
msgid ""
"When enabled, using Ctrl+Click will suspend the computer immediately, "
"without starting a count down or waiting for an existing count down to "
"finish."
msgstr ""
"Når aktiveret sættes computeren øjeblikkeligt i hviletilstand med Ctrl-"
"klik uden at starte en nedtælling eller vente på en nedtælling er færdig."

#. settings-schema.json->fullcolor-icon->description
msgid "Use a full color icon"
msgstr "Brug et fuldfarveikon"

#. settings-schema.json->fullcolor-icon->tooltip
msgid ""
"When enabled, a full color panel icon will be used, otherwise a symbolic "
"icon will be used."
msgstr ""
"Når denne funktion er aktiveret, vises der et ikon i fuld farve; ellers "
"vises der et symbolsk ikon."

#. settings-schema.json->system-suspend-header->description
msgid "System suspend settings"
msgstr "Systemets indstillinger for hviletilstand"

#. settings-schema.json->config-power->description
msgid "Open Power Management Settings"
msgstr "Åbn indstillingerne for strømstyring"
