#. metadata.json->description
msgid "Display the next meeting from your calendar in the menu bar."
msgstr ""
"Affiche la prochaine réunion de votre calendrier dans la barre de menus."

#. settings-schema.json->ical-urls->description
msgid "iCal Calendar URLs"
msgstr "URL des calendriers iCal"

#. settings-schema.json->ical-urls->tooltip
msgid "Enter one iCal (.ics) URL per line. You can add multiple calendars."
msgstr ""
"Saisissez une URL iCal (.ics) par ligne. Vous pouvez ajouter plusieurs "
"calendriers."

#. settings-schema.json->refresh-rate->description
msgid "Refresh Rate"
msgstr "Fréquence d'actualisation"

#. settings-schema.json->refresh-rate->units
msgid "minutes"
msgstr "minutes"

#. settings-schema.json->refresh-rate->tooltip
msgid "How often to fetch calendar updates"
msgstr "Fréquence de récupération des mises à jour du calendrier"

#. settings-schema.json->padding->description
msgid "Padding"
msgstr "Marge interne"

#. settings-schema.json->padding->units
msgid "pixels"
msgstr "pixels"

#. settings-schema.json->padding->tooltip
msgid "Padding around the text on all sides"
msgstr "Marge interne autour du texte sur tous les côtés"

#. settings-schema.json->max-text-length->description
msgid "Max Text Length"
msgstr "Longueur maximale du texte"

#. settings-schema.json->max-text-length->units
msgid "characters"
msgstr "caractères"

#. settings-schema.json->max-text-length->tooltip
msgid "Maximum event title length (truncated with ...)"
msgstr "Longueur maximale du titre de l'événement (tronqué avec ...)"

#. settings-schema.json->show-tomorrow-events->description
msgid "Show Tomorrow's Events"
msgstr "Afficher les événements de demain"

#. settings-schema.json->show-tomorrow-events->tooltip
msgid "Include events from tomorrow in addition to today's events"
msgstr "Inclure les événements de demain en plus de ceux d'aujourd'hui"

#. settings-schema.json->refresh-calendars->description
msgid "Refresh Calendars Now"
msgstr "Actualiser les calendriers maintenant"

#. settings-schema.json->refresh-calendars->tooltip
msgid "Immediately refresh all calendars and show status"
msgstr "Actualiser immédiatement tous les calendriers et afficher l'état"

#. settings-schema.json->menu-colors-header->description
msgid "Menu Event Colors"
msgstr "Couleurs des événements du menu"

#. settings-schema.json->past-event-color->description
msgid "Past Event Color"
msgstr "Couleur des événements passés"

#. settings-schema.json->past-event-color->tooltip
msgid "Color for events that have already happened"
msgstr "Couleur des événements déjà passés"

#. settings-schema.json->current-event-color->description
msgid "Current Event Color"
msgstr "Couleur de l'événement en cours"

#. settings-schema.json->current-event-color->tooltip
msgid "Color for the event happening now"
msgstr "Couleur de l'événement en cours"

#. settings-schema.json->future-event-color->description
msgid "Future Event Color"
msgstr "Couleur des événements à venir"

#. settings-schema.json->future-event-color->tooltip
msgid "Color for upcoming events"
msgstr "Couleur des événements à venir"
