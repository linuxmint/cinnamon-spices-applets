#. settings-schema.json->focus_ambient_file->description
msgid "Ambient sound file"
msgstr "Háttérhang fájl"

#. settings-schema.json->focus_ambient_file->tooltip
msgid ""
"Pick your own looping ambient sound. Leave empty for the built-in soft brown "
