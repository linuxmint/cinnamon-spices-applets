#. settings-schema.json->break_sound_test->description
#. settings-schema.json->warn_sound_test->description
#. settings-schema.json->start_sound_test->description
#. settings-schema.json->interval_chime_test->description
msgid "Listen"
msgstr "Écouter"

#. settings-schema.json->timer_sound_test->tooltip
#. settings-schema.json->break_sound_test->tooltip
#. settings-schema.json->warn_sound_test->tooltip
#. settings-schema.json->start_sound_test->tooltip
