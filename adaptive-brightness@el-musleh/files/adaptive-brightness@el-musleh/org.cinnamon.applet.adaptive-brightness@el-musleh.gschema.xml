<?xml version="1.0" encoding="UTF-8"?>
<gsettings-schema>
    <key type="i" name="min-brightness">
        <default>10</default>
        <summary>Minimum Brightness</summary>
        <description>Minimum brightness level in percentage (1-100)</description>
    </key>
    
    <key type="i" name="max-brightness">
        <default>100</default>
        <summary>Maximum Brightness</summary>
        <description>Maximum brightness level in percentage (1-100)</description>
    </key>
    
    <key type="d" name="smoothing-factor">
        <default>0.2</default>
        <summary>Smoothing Factor</summary>
        <description>How smooth the brightness transitions are (0.0-1.0)</description>
    </key>
    
    <key type="b" name="calibrate-max-lux">
        <default>false</default>
        <summary>Start Auto-Calibration</summary>
        <description>Click to detect maximum light level over 30s</description>
    </key>
    
    <key type="i" name="max-lux">
        <default>10000</default>
        <summary>Maximum Lux</summary>
        <description>Maximum ambient light value (100-100000)</description>
    </key>
    
    <key type="i" name="poll-interval">
        <default>1000</default>
        <summary>Poll Interval</summary>
        <description>How often to check sensor in milliseconds (100-60000)</description>
    </key>

    <key type="i" name="min-lux">
        <default>0</default>
        <summary>Minimum Lux</summary>
        <description>Ambient lux at or below which minimum brightness is applied</description>
    </key>

    <key type="b" name="calibrate-min-lux">
        <default>false</default>
        <summary>Calibrate Dark Level</summary>
        <description>Triggers dark-phase calibration to detect noise floor</description>
    </key>

    <key type="s" name="sensor-path">
        <default>''</default>
        <summary>Sensor Path Override</summary>
        <description>Manual IIO device path; empty = auto-detect</description>
    </key>
</gsettings-schema>
