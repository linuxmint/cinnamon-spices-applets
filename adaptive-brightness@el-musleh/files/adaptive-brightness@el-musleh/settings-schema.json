{
  "min-brightness": {
    "type": "spinbutton",
    "default": 10,
    "min": 1,
    "max": 100,
    "step": 1,
    "units": "%",
    "title": "Minimum Brightness",
    "description": "Minimum brightness level (percentage)"
  },
  "max-brightness": {
    "type": "spinbutton",
    "default": 90,
    "min": 1,
    "max": 100,
    "step": 1,
    "units": "%",
    "title": "Maximum Brightness",
    "description": "Maximum brightness level (percentage)"
  },
  "smoothing-factor": {
    "type": "scale",
    "default": 0.2,
    "min": 0.0,
    "max": 1.0,
    "step": 0.05,
    "title": "Smoothing Factor",
    "description": "Brightness transition smoothness: 0=instant, 1=very smooth"
  },
  "max-lux": {
    "type": "spinbutton",
    "default": 10000,
    "min": 100,
    "max": 100000,
    "step": 100,
    "title": "Maximum Lux",
    "description": "Reference ambient light level for maximum brightness"
  },
  "poll-interval": {
    "type": "spinbutton",
    "default": 1000,
    "min": 100,
    "max": 60000,
    "step": 100,
    "units": "ms",
    "title": "Poll Interval",
    "description": "Sensor check frequency in milliseconds"
  }
}

