{
  "env": {
    "browser": false,
    "es2021": true,
    "node": true
  },
  "globals": {
    "imports": "readonly",
    "global": "readonly",
    "ABLogger": "writable",
    "main": "writable",
    "AdaptiveBrightnessApplet": "writable"
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "constructor-super": "off",
    "no-this-before-super": "off",
    "no-empty": ["error", { "allowEmptyCatch": true }],
    "no-magic-numbers": "warn",
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_", "varsIgnorePattern": "^main$" }],
    "no-console": "off"
  }
}
